<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Feedback Form - Emergency Services | DMC & Hospital, Ludhiana</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 25%, #f093fb 50%, #4facfe 75%, #00f2fe 100%);
    background-size: 400% 400%;
    animation: bgShift 10s ease infinite;
    min-height: 100vh;
    padding: 30px 16px 50px;
  }

  @keyframes bgShift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes popIn {
    0%   { transform: scale(0.8); opacity: 0; }
    70%  { transform: scale(1.1); }
    100% { transform: scale(1);   opacity: 1; }
  }

  .form-container {
    max-width: 720px;
    margin: 0 auto;
    background: rgba(255,255,255,0.97);
    padding: 40px 48px;
    border-radius: 28px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.22);
    animation: fadeUp 0.7s ease;
    position: relative;
    overflow: hidden;
  }

  .form-container::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 6px;
    background: linear-gradient(90deg, #667eea, #f093fb, #4facfe, #00f2fe, #43e97b);
  }

  .logo-center { display: flex; justify-content: center; margin-bottom: 14px; }
  .logo-center img { height: 100px; max-width: 100%; object-fit: contain; }

  .form-title {
    font-size: 22px; font-weight: 700;
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    text-align: center; margin-bottom: 4px;
  }
  .form-title-pa { font-size: 18px; font-weight: 600; color: #764ba2; text-align: center; margin-bottom: 6px; }
  .form-sub { font-size: 13px; color: #6b7280; text-align: center; margin-bottom: 3px; }

  .divider {
    border: none; height: 2px; margin: 22px 0;
    background: linear-gradient(90deg, transparent, #e0e7ff, #f3e8ff, #e0e7ff, transparent);
  }

  /* Field cards */
  .field-card {
    border-radius: 16px; padding: 18px 20px; margin-bottom: 18px;
    border: 1.5px solid #bae6fd;
    background: linear-gradient(135deg, #f0f9ff, #e0f2fe);
  }
  .field-card.green  { background: linear-gradient(135deg, #f0fdf4, #dcfce7); border-color: #bbf7d0; }
  .field-card.purple { background: linear-gradient(135deg, #faf5ff, #ede9fe); border-color: #ddd6fe; }
  .field-card.orange { background: linear-gradient(135deg, #fff7ed, #ffedd5); border-color: #fed7aa; }

  .field-card-title {
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em;
    margin-bottom: 16px; display: flex; align-items: center; gap: 6px;
  }
  .field-card       .field-card-title { color: #0369a1; }
  .field-card.green .field-card-title { color: #15803d; }
  .field-card.purple .field-card-title { color: #7c3aed; }
  .field-card.orange .field-card-title { color: #c2410c; }
  .field-card .input-group:last-child { margin-bottom: 0; }

  /* Floating label */
  .input-group { position: relative; margin-bottom: 22px; }
  .input-field {
    width: 100%; padding: 18px 14px 8px;
    border: 2px solid #e5e7eb; border-radius: 12px;
    font-size: 15px; outline: none;
    background: #fafaff; color: #111;
    transition: border-color .2s, box-shadow .2s;
    font-family: 'Poppins', sans-serif;
  }
  .input-field:focus { border-color: #667eea; background: #fff; box-shadow: 0 0 0 4px rgba(102,126,234,.13); }

  .floating-label {
    position: absolute; top: 13px; left: 14px;
    font-size: 14px; color: #9ca3af;
    pointer-events: none; transition: .2s ease all; line-height: 1.4;
  }
  .floating-label .pa { display: block; font-size: 11px; color: #c4b5fd; }

  .input-field:focus + .floating-label,
  .input-field:not(:placeholder-shown) + .floating-label,
  .input-field.has-value + .floating-label {
    top: 4px; font-size: 10px; color: #667eea; font-weight: 600;
  }
  .input-field:focus + .floating-label .pa,
  .input-field:not(:placeholder-shown) + .floating-label .pa,
  .input-field.has-value + .floating-label .pa { display: none; }

  select.input-field { padding-top: 18px; padding-bottom: 8px; appearance: none; cursor: pointer; }
  textarea.input-field { min-height: 90px; resize: vertical; padding-top: 22px; }
  .sel-arrow { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); pointer-events: none; color: #667eea; font-size: 18px; }

  .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
  @media (max-width: 540px) {
    .row2 { grid-template-columns: 1fr; }
    .row3 { grid-template-columns: 1fr 1fr; }
    .form-container { padding: 28px 20px; }
    .sat-row { grid-template-columns: 1fr 1fr; }
  }

  /* ── Satisfaction emoji buttons ── */
  .sat-section-label { font-size: 15px; font-weight: 700; color: #374151; margin-bottom: 4px; }
  .sat-section-label-pa { font-size: 12px; color: #9ca3af; margin-bottom: 18px; }

  .sat-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-bottom: 6px; }

  .sat-btn {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; padding: 24px 16px;
    border: 2.5px solid #e5e7eb; border-radius: 22px;
    cursor: pointer; background: #fafaff;
    transition: all .22s ease; position: relative; overflow: hidden;
  }
  .sat-btn::before {
    content: ''; position: absolute; inset: 0; opacity: 0; transition: opacity .25s;
    border-radius: inherit;
  }
  .sat-btn:hover { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,.1); }

  .sat-btn.btn-sat::before { background: linear-gradient(135deg, #d1fae5, #a7f3d0); }
  .sat-btn.btn-sat:hover    { border-color: #10b981; }
  .sat-btn.btn-sat.active   { border-color: #10b981; transform: translateY(-5px); box-shadow: 0 14px 36px rgba(16,185,129,.25); }
  .sat-btn.btn-sat.active::before { opacity: 1; }

  .sat-btn.btn-dis::before { background: linear-gradient(135deg, #fee2e2, #fecaca); }
  .sat-btn.btn-dis:hover    { border-color: #ef4444; }
  .sat-btn.btn-dis.active   { border-color: #ef4444; transform: translateY(-5px); box-shadow: 0 14px 36px rgba(239,68,68,.25); }
  .sat-btn.btn-dis.active::before { opacity: 1; }

  .sat-emoji {
    font-size: 58px; line-height: 1; position: relative; z-index: 1;
    filter: drop-shadow(0 4px 10px rgba(0,0,0,.18));
    transition: transform .2s;
    display: block;
  }
  .sat-btn:hover .sat-emoji { transform: scale(1.18) rotate(-6deg); }
  .sat-btn.active .sat-emoji { animation: popIn .35s ease forwards; }

  .sat-label     { font-size: 15px; font-weight: 700; position: relative; z-index: 1; text-align: center; }
  .sat-label-pa  { font-size: 12px; font-weight: 400; position: relative; z-index: 1; text-align: center; }
  .btn-sat .sat-label    { color: #065f46; }
  .btn-sat .sat-label-pa { color: #059669; }
  .btn-dis .sat-label    { color: #7f1d1d; }
  .btn-dis .sat-label-pa { color: #dc2626; }

  /* ── Categories ── */
  .cat-section {
    margin-top: 18px; padding: 20px;
    background: linear-gradient(135deg, #fff5f5, #fef3c7);
    border-radius: 18px; border: 2px dashed #fca5a5;
  }
  .cat-head { font-size: 14px; font-weight: 700; color: #dc2626; margin-bottom: 4px; }
  .cat-sub  { font-size: 11px; color: #f59e0b; font-weight: 500; margin-bottom: 14px; }

  .cat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; }
  @media (max-width: 540px) { .cat-grid { grid-template-columns: 1fr; } }

  .cat-item {
    display: flex; align-items: flex-start; gap: 9px;
    padding: 11px 13px;
    background: #fff; border: 2px solid #fed7d7; border-radius: 12px;
    cursor: pointer; transition: all .15s;
  }
  .cat-item:hover { border-color: #f87171; background: #fff5f5; transform: translateX(2px); }
  .cat-item.on    { border-color: #ef4444; background: linear-gradient(135deg, #fee2e2, #fff); box-shadow: 0 4px 12px rgba(239,68,68,.15); }
  .cat-item input[type=checkbox] { width: 16px; height: 16px; accent-color: #ef4444; margin-top: 2px; flex-shrink: 0; cursor: pointer; }
  .cat-item .ct      { font-size: 12px; color: #374151; line-height: 1.4; font-weight: 500; }
  .cat-item .ct span { display: block; font-size: 10.5px; color: #9ca3af; font-weight: 400; }

  /* ── Submit ── */
  .submit-btn {
    width: 100%; padding: 16px 0;
    background: linear-gradient(135deg, #667eea, #764ba2, #f093fb);
    background-size: 200% 200%;
    color: #fff; border: none; border-radius: 14px;
    font-size: 17px; font-weight: 700; cursor: pointer;
    font-family: 'Poppins', sans-serif;
    display: flex; align-items: center; justify-content: center; gap: 10px;
    transition: all .3s ease; margin-top: 10px;
    box-shadow: 0 8px 24px rgba(102,126,234,.4);
  }
  .submit-btn:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(102,126,234,.55); background-position: right center; }
  .submit-btn:active { transform: translateY(0); }

  .hidden { display: none !important; }

  /* ── Success ── */
  .success-card {
    text-align: center; padding: 3rem 2rem;
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    border-radius: 24px; border: 2px solid #86efac;
    animation: fadeUp .6s ease;
  }
  .success-emoji { font-size: 64px; margin-bottom: 8px; animation: popIn .5s ease; display: block; }
  .success-card h2 { font-size: 22px; font-weight: 700; color: #065f46; margin-bottom: 8px; }
  .success-card p  { font-size: 14px; color: #047857; line-height: 1.7; }
</style>
</head>
<body>

<div class="form-container" id="formWrap">

  <div class="logo-center">
    <img src="/app-assets/1 (4).png" alt="DMC Hospital Logo">
  </div>

  <h2 class="form-title">Feedback Form – Emergency Services</h2>
  <h2 class="form-title-pa">ਫੀਡਬੈਕ ਫਾਰਮ – ਐਮਰਜੈਂਸੀ ਸੇਵਾਵਾਂ</h2>
  <p class="form-sub">Thank you for your visit to DMC &amp; Hospital, Ludhiana</p>
  <p class="form-sub">ਡੀ ਐਮ ਸੀ ਅਤੇ ਹਸਪਤਾਲ, ਲੁਧਿਆਣਾ ਵਿਖੇ ਆਉਣ ਲਈ ਤੁਹਾਡਾ ਧੰਨਵਾਦ</p>

  <hr class="divider">

  <form id="feedbackForm" action="/Create_category" method="POST" enctype="multipart/form-data">

    <!-- Patient Info -->
    <div class="field-card">
      <div class="field-card-title"><i class="ti ti-user-circle"></i> Patient Information / ਮਰੀਜ਼ ਦੀ ਜਾਣਕਾਰੀ</div>

      <!-- MRD Number (first) -->
      <div class="input-group">
        <input type="number" name="mrdnumber" class="input-field" placeholder=" " required>
        <label class="floating-label">MRD Number <span class="pa">ਐਮ ਆਰ ਡੀ ਨੰਬਰ</span></label>
      </div>

      <!-- Patient Name (second) -->
      <div class="input-group">
        <input type="text" name="name" class="input-field" placeholder=" " required>
        <label class="floating-label">Patient Name <span class="pa">ਮਰੀਜ਼ ਦਾ ਨਾਮ</span></label>
      </div>

      <!-- Age / Gender combined single input -->
      <div class="input-group">
        <input type="text" name="age_gender" class="input-field" placeholder=" " required>
        <label class="floating-label">Age / Gender <span class="pa">ਉਮਰ / ਲਿੰਗ</span></label>
      </div>

      <!-- Admission Date + Contact Number side by side -->
      <div class="row2">
        <div class="input-group">
          <input type="date" name="date" class="input-field" required oninput="this.classList.add('has-value')">
          <label class="floating-label">Admission Date <span class="pa">ਦਾਖਲੇ ਦੀ ਮਿਤੀ</span></label>
        </div>
        <div class="input-group">
          <input type="tel" name="number" class="input-field" placeholder=" " required>
          <label class="floating-label">Contact Number <span class="pa">ਮੋਬਾਈਲ ਨੰਬਰ</span></label>
        </div>
      </div>
    </div>

    <!-- Doctor + Bed No -->
    <div class="field-card green">
      <div class="field-card-title"><i class="ti ti-stethoscope"></i> Emergency Details / ਐਮਰਜੈਂਸੀ ਵੇਰਵੇ</div>

      <div class="input-group">
        <select name="doctorComplaint" class="input-field" required onchange="this.classList.add('has-value')">
          <option value="" disabled selected hidden></option>
          <option>Dr. Aarish Bali</option><option>Dr. Ajit Sood</option><option>Dr. Akashdeep Singh</option>
          <option>Dr. Alka Gupta Grewal</option><option>Dr. Amandeep Singh</option><option>Dr. Amandeep Singh Nar</option>
          <option>Dr. Anil Kumar Kashyap</option><option>Dr. Anubhav Sharma</option><option>Dr. Arshdeep Singh</option>
          <option>Dr. Ashima Taneja</option><option>Dr. Ashish Ahuja</option><option>Dr. Ashvind Bawa</option>
          <option>Dr. Ashwani K. Chaudhary</option><option>Dr. Atul Mishra</option><option>Dr. Barinder Singh Paul</option>
          <option>Dr. Deepak Bhatt</option><option>Dr. Deepak Jain</option><option>Dr. Dhananjay Gupta</option>
          <option>Dr. Dinesh Jain</option><option>Dr. Gagandeep Singh</option><option>Dr. Gurdeep S. Dhooria</option>
          <option>Dr. Gurmeet Singh</option><option>Dr. Gurpreet Singh</option><option>Dr. Gurvinder Kaur</option>
          <option>Dr. Hanish Bansal</option><option>Dr. Harmandeep Singh Chahal</option><option>Dr. Harmeet Pal Singh Dhooria</option>
          <option>Dr. Harpal Singh</option><option>Dr. Isha</option><option>Dr. Jagminder Singh</option>
          <option>Dr. Jaspriya Sandhu</option><option>Dr. Jatinder Singh Goraya</option><option>Dr. Joban Preet Deol</option>
          <option>Dr. Jyoti Jindal</option><option>Dr. Kajal Arora</option><option>Dr. Kamaldeep Arora</option>
          <option>Dr. Kanwar Aggarwal</option><option>Dr. Karambir Singh Gill</option><option>Dr. Kunwar Aggarwal</option>
          <option>Dr. Mitthat Miglani</option><option>Dr. Monica</option><option>Dr. Monika Singla</option>
          <option>Dr. Munish Trehan</option><option>Dr. Namita Bhuhiraja</option><option>Dr. Narinder Pal Jain</option>
          <option>Dr. Naveen Mitaal</option><option>Dr. Navkiran Mahajan</option><option>Dr. Navneet Kaur</option>
          <option>Dr. Omesh Goyal</option><option>Dr. Pallavi Singh</option><option>Dr. Pankaj Kumar</option>
          <option>Dr. Pankaj MahinDra</option><option>Dr. Parveen Goel</option><option>Dr. Poornima Sharma</option>
          <option>Dr. Pooja Tondon</option><option>Dr. Prabhdeep Singh</option><option>Dr. Prabhdeep Singh Nain</option>
          <option>Dr. Priyanka Arora</option><option>Dr. Puneet A. Pooni</option><option>Dr. Purnendu Bhardwah</option>
          <option>Dr. Rajesh Mahajan</option><option>Dr. Rajinder Mittal</option><option>Dr. Rajnish Garg</option>
          <option>Dr. Ramit Mahajan</option><option>Dr. Ramneesh Garg</option><option>Dr. Rashmi Malhotra</option>
          <option>Dr. Ravinder Pal Singh</option><option>Dr. Rita Rai</option><option>Dr. Ritesh Verma</option>
          <option>Dr. Rohit Verma</option><option>Dr. Sahil Maingi</option><option>Dr. Sandeep Chhabra</option>
          <option>Dr. Sandeep Sharma</option><option>Dr. Sanjeev K. Singla</option><option>Dr. Sanjeev Puri</option>
          <option>Dr. Saurabh</option><option>Dr. Sheerin Shah</option><option>Dr. Shivender Sobti</option>
          <option>Dr. Sidharth Bhargava</option><option>Dr. Simran Kaur</option><option>Dr. Sukhjot Kaur</option>
          <option>Dr. Sumti Verma</option><option>Dr. Suman Puri</option><option>Dr. Sunil Juneja</option>
          <option>Dr. Tanish Dhir</option><option>Dr. Vandana Midha</option><option>Dr. Varun Gupta</option>
          <option>Dr. Varun Mehta</option><option>Dr. Vikas Garg</option><option>Dr. Vikas Kumar</option>
          <option>Dr. Vikas Makkar</option><option>Dr. Vineet Galhotraa</option><option>Dr. Vipin Kumar</option>
          <option>Dr. Yogesh Gupta</option>
        </select>
        <label class="floating-label">Doctor Name <span class="pa">ਡਾਕਟਰ ਦਾ ਨਾਮ</span></label>
        <i class="ti ti-chevron-down sel-arrow"></i>
      </div>

      <div class="input-group" style="margin-bottom:0;">
        <input type="text" name="bedNo" class="input-field" placeholder=" " required>
        <label class="floating-label">Bed No. <span class="pa">ਬੈੱਡ ਨੰਬਰ</span></label>
      </div>
    </div>

    <!-- Satisfaction -->
    <div class="field-card purple">
      <div class="field-card-title"><i class="ti ti-mood-happy"></i> Service Feedback / ਸੇਵਾ ਫੀਡਬੈਕ</div>

      <div class="sat-section-label">Were you satisfied with the hospital services?</div>
      <div class="sat-section-label-pa">ਕੀ ਤੁਸੀਂ ਹਸਪਤਾਲ ਵੱਲੋਂ ਦਿੱਤੀਆਂ ਗਈਆਂ ਸੇਵਾਵਾਂ ਨਾਲ ਸੰਤੁਸ਼ਟ ਹੋ?</div>

      <div class="sat-row">
        <div class="sat-btn btn-sat" id="btnS" onclick="setSat('satisfied')">
          <span class="sat-emoji">😊</span>
          <div class="sat-label">Satisfied</div>
          <div class="sat-label-pa">ਸੰਤੁਸ਼ਟ</div>
        </div>
        <div class="sat-btn btn-dis" id="btnD" onclick="setSat('dissatisfied')">
          <span class="sat-emoji">😞</span>
          <div class="sat-label">Dissatisfied</div>
          <div class="sat-label-pa">ਅਸੰਤੁਸ਼ਟ</div>
        </div>
      </div>

      <input type="hidden" id="satValue" name="services" value="">

      <!-- Categories shown when dissatisfied -->
      <div id="catBlock" class="hidden">
        <div class="cat-section">
          <div class="cat-head">😟 Areas needing improvement / ਸੁਧਾਰ ਦੀ ਲੋੜ ਵਾਲੇ ਖੇਤਰ</div>
          <div class="cat-sub">Please select all that apply / ਜੋ ਲਾਗੂ ਹੋਵੇ ਉਹ ਚੁਣੋ</div>
          <div class="cat-grid" id="catGrid"></div>
        </div>
      </div>

      <!-- Suggestion textarea -->
      <div class="input-group" style="margin-top:20px;margin-bottom:0;">
        <textarea name="Suggestion" class="input-field" placeholder=" "></textarea>
        <label class="floating-label">Suggestions for improvement <span class="pa">ਕਿਰਪਾ ਕਰਕੇ ਆਪਣੇ ਸੁਝਾਅ ਦਿਓ</span></label>
      </div>
    </div>

    <!-- Submitted by -->
    <div class="field-card orange">
      <div class="field-card-title"><i class="ti ti-pencil"></i> Additional Details / ਵਾਧੂ ਜਾਣਕਾਰੀ</div>

      <div class="input-group">
        <input type="text" name="submited" class="input-field" placeholder=" " required>
        <label class="floating-label">Submitted by <span class="pa">ਕਿਸ ਦੁਆਰਾ ਜਮ੍ਹਾ ਕੀਤਾ ਗਿਆ</span></label>
      </div>
    </div>

    <button type="submit" class="submit-btn">
      <i class="ti ti-send" style="font-size:20px;"></i>
      Submit / ਜਮ੍ਹਾ ਕਰੋ
    </button>

  </form>
</div>

<!-- Success screen -->
<div id="successBlock" class="hidden" style="max-width:720px;margin:60px auto;padding:0 16px;">
  <div class="success-card">
    <span class="success-emoji">🎉</span>
    <h2>Thank you! / ਧੰਨਵਾਦ!</h2>
    <p>Your response has been submitted successfully.<br>ਤੁਹਾਡਾ ਜਵਾਬ ਸਫਲਤਾਪੂਰਵਕ ਜਮ੍ਹਾ ਕਰ ਦਿੱਤਾ ਗਿਆ ਹੈ।</p>
  </div>
</div>

<script>
const cats = [
  ["Ambulance Services",                                        "ਐਂਬੂਲੈਂਸ ਸੇਵਾਵਾਂ",                          "Ambulance Services"],
  ["Wheelchair / Trolley Availability",                         "ਵ੍ਹੀਲਚੇਅਰ / ਟ੍ਰਾਲੀ ਦੀ ਉਪਲਬਧਤਾ",             "Wheelchair and Trolley Availability"],
  ["Emergency Waiting Time",                                    "ਐਮਰਜੈਂਸੀ ਉਡੀਕ ਸਮਾਂ",                        "Emergency Waiting Time"],
  ["Registration and Billing Process",                          "ਰਜਿਸਟ੍ਰੇਸ਼ਨ ਅਤੇ ਬਿਲਿੰਗ ਪ੍ਰਕਿਰਿਆ",           "Registration and Billing Process"],
  ["Nursing Care",                                              "ਨਰਸਿੰਗ ਦੇਖਭਾਲ",                              "Nursing Care"],
  ["Doctor Consultation",                                       "ਡਾਕਟਰ ਦੀ ਸਲਾਹ",                             "Doctor Consultation"],
  ["Guidance and Information on Treatment",                     "ਇਲਾਜ ਬਾਰੇ ਮਾਰਗਦਰਸ਼ਨ ਅਤੇ ਜਾਣਕਾਰੀ",           "Guidance and Information on Treatment"],
  ["Cleanliness and Hygiene",                                   "ਸਫ਼ਾਈ ਅਤੇ ਸਵੱਛਤਾ",                          "Cleanliness and Hygiene"],
  ["Diagnostics (Radiology, X-ray, MRI, CT scan, Laboratory)", "ਡਾਇਗਨੋਸਟਿਕ ਸੇਵਾਵਾਂ",                        "Diagnostics"],
  ["Pharmacy and Medicine Related Information",                 "ਦਵਾਈਆਂ ਅਤੇ ਫਾਰਮੇਸੀ ਸੰਬੰਧੀ ਜਾਣਕਾਰੀ",         "Pharmacy and Medicine Related Information"],
  ["Staff Behaviour",                                           "ਸਟਾਫ ਦਾ ਵਿਹਾਰ",                              "Staff Behaviour"],
  ["Discharge Process",                                         "ਛੁੱਟੀ ਦੇਣ ਦੀ ਪ੍ਰਕਿਰਿਆ",                     "Discharge Process"],
  ["Any Other Concern",                                         "ਹੋਰ ਕੋਈ ਸਮੱਸਿਆ",                             "Any Other Concern"]
];

const grid = document.getElementById('catGrid');
cats.forEach(([en, pa, val], i) => {
  const d = document.createElement('div');
  d.className = 'cat-item'; d.id = 'c' + i;
  d.innerHTML = `<input type="checkbox" name="facilities" value="${val}" id="cb${i}" onchange="tog(${i})">
    <div class="ct">${en}<span>${pa}</span></div>`;
  d.onclick = e => {
    if (e.target.tagName !== 'INPUT') {
      const cb = document.getElementById('cb' + i);
      cb.checked = !cb.checked; tog(i);
    }
  };
  grid.appendChild(d);
});

function tog(i) {
  document.getElementById('c' + i).classList.toggle('on', document.getElementById('cb' + i).checked);
}

let sat = '';
function setSat(v) {
  sat = v;
  document.getElementById('satValue').value = v === 'satisfied' ? 'Satisfied' : 'Dissatisfied';
  document.getElementById('btnS').classList.toggle('active', v === 'satisfied');
  document.getElementById('btnD').classList.toggle('active', v === 'dissatisfied');
  const block = document.getElementById('catBlock');
  if (v === 'dissatisfied') {
    block.classList.remove('hidden');
  } else {
    block.classList.add('hidden');
    document.querySelectorAll('#catGrid input').forEach(c => c.checked = false);
    document.querySelectorAll('.cat-item').forEach(d => d.classList.remove('on'));
  }
}

document.getElementById('feedbackForm').addEventListener('submit', function(e) {
  e.preventDefault();
  if (!sat) {
    Swal.fire({ title: 'Please select!', text: 'Kindly select Satisfied or Dissatisfied / ਸੰਤੁਸ਼ਟ ਜਾਂ ਅਸੰਤੁਸ਼ਟ ਚੁਣੋ।', icon: 'warning', confirmButtonColor: '#667eea' });
    return;
  }
  fetch('/Create_category', { method: 'POST', body: new FormData(this) })
    .then(r => r.text())
    .then(() => {
      Swal.fire({
        title: '🎉 Success! / ਸਫਲ!',
        text: 'Your response has been submitted. / ਤੁਹਾਡਾ ਜਵਾਬ ਜਮ੍ਹਾ ਕਰ ਦਿੱਤਾ ਗਿਆ।',
        icon: 'success', confirmButtonText: 'OK', confirmButtonColor: '#667eea'
      }).then(() => {
        this.reset(); sat = '';
        document.getElementById('btnS').classList.remove('active');
        document.getElementById('btnD').classList.remove('active');
        document.getElementById('catBlock').classList.add('hidden');
        document.querySelectorAll('.cat-item').forEach(d => d.classList.remove('on'));
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    })
    .catch(() => {
      Swal.fire({ title: 'Error!', text: 'Something went wrong. Please try again.', icon: 'error', confirmButtonColor: '#667eea' });
    });
});
</script>
</body>
</html>