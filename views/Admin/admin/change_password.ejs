<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🤖 Robot Voice Studio</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Share+Tech+Mono&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;}

:root{
  --bg:#060810;
  --surface:#0c1020;
  --surface2:#121830;
  --accent:#00e5ff;
  --accent2:#7c4dff;
  --green:#00e676;
  --text:#e0f0ff;
  --text2:#6080a0;
  --border:rgba(0,229,255,0.15);
}

body{
  font-family:'Inter',sans-serif;
  background:var(--bg);
  min-height:100vh;
  display:flex; align-items:flex-start; justify-content:center;
  padding:30px 20px 40px;
  position:relative; overflow-y:auto; overflow-x:hidden;
}

/* grid bg */
body::before{
  content:''; position:fixed; inset:0; pointer-events:none;
  background-image:
    linear-gradient(rgba(0,229,255,0.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,229,255,0.04) 1px,transparent 1px);
  background-size:40px 40px;
}
body::after{
  content:''; position:fixed; inset:0; pointer-events:none;
  background:radial-gradient(ellipse 70% 60% at 50% 0%,rgba(124,77,255,0.12),transparent);
}

.card{
  position:relative; z-index:1;
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:20px;
  padding:36px 40px;
  width:min(680px,96vw);
  box-shadow:0 0 60px rgba(0,229,255,0.06);
}
.card::before{
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg,var(--accent2),var(--accent),var(--accent2));
  border-radius:20px 20px 0 0;
}

/* ROBOT HEAD */
.robot-head{
  text-align:center; margin-bottom:28px;
}
.robot-face{
  width:80px; height:80px; margin:0 auto 12px;
  background:var(--surface2); border:2px solid var(--accent);
  border-radius:14px; position:relative;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 0 20px rgba(0,229,255,0.2);
  animation:floatBot 3s ease-in-out infinite;
}
@keyframes floatBot{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
.robot-eyes{display:flex;gap:12px;align-items:center;}
.eye{
  width:12px; height:12px; border-radius:50%;
  background:var(--accent);
  box-shadow:0 0 8px var(--accent);
  animation:blink 3s ease-in-out infinite;
}
.eye:last-child{animation-delay:.2s;}
@keyframes blink{0%,90%,100%{transform:scaleY(1)}95%{transform:scaleY(0.1)}}
.robot-mouth{
  position:absolute; bottom:14px; left:50%; transform:translateX(-50%);
  width:28px; height:4px; background:var(--accent);
  border-radius:2px; box-shadow:0 0 6px var(--accent);
  transition:all .3s;
}
.robot-mouth.speaking{
  height:8px; border-radius:4px;
  animation:mouthAnim .15s steps(1) infinite;
}
@keyframes mouthAnim{
  0%{width:28px;height:8px;}
  25%{width:20px;height:12px;}
  50%{width:30px;height:6px;}
  75%{width:18px;height:10px;}
}

.title{
  font-family:'Orbitron',sans-serif;
  font-size:22px; font-weight:900; letter-spacing:2px;
  color:var(--text); margin-bottom:4px;
}
.title span{color:var(--accent);}
.subtitle{font-size:13px; color:var(--text2); letter-spacing:1px;}

/* TEXTAREA */
.input-label{
  font-family:'Orbitron',sans-serif;
  font-size:10px; font-weight:700; letter-spacing:3px; text-transform:uppercase;
  color:var(--text2); margin-bottom:8px; display:block;
}
textarea{
  width:100%; min-height:160px;
  background:var(--surface2); border:1px solid var(--border);
  border-radius:12px; padding:16px;
  font-family:'Share Tech Mono',monospace;
  font-size:14px; color:var(--text); line-height:1.7;
  resize:vertical; outline:none;
  transition:border-color .2s, box-shadow .2s;
}
textarea:focus{
  border-color:rgba(0,229,255,0.4);
  box-shadow:0 0 0 3px rgba(0,229,255,0.08);
}
textarea::placeholder{color:var(--text2); font-style:italic;}

/* CONTROLS */
.controls{
  display:grid; grid-template-columns:1fr 1fr; gap:14px; margin:16px 0;
}
.control-item label{
  font-size:11px; color:var(--text2); letter-spacing:1px;
  text-transform:uppercase; display:block; margin-bottom:6px;
}
.control-item .val{
  float:right; color:var(--accent);
  font-family:'Share Tech Mono',monospace; font-size:11px;
}

input[type=range]{
  width:100%; appearance:none; height:4px;
  background:var(--surface2); border-radius:2px; outline:none;
  cursor:pointer;
}
input[type=range]::-webkit-slider-thumb{
  appearance:none; width:16px; height:16px; border-radius:50%;
  background:var(--accent); cursor:pointer;
  box-shadow:0 0 8px var(--accent);
}

select{
  width:100%; background:var(--surface2); border:1px solid var(--border);
  border-radius:8px; padding:10px 12px;
  color:var(--text); font-family:'Share Tech Mono',monospace; font-size:13px;
  outline:none; cursor:pointer; appearance:none;
}
select option{background:var(--surface2);}

/* SPEAK BUTTON */
.speak-btn{
  width:100%; padding:16px;
  background:linear-gradient(135deg,var(--accent2),var(--accent));
  color:#000; border:none; border-radius:12px;
  font-family:'Orbitron',sans-serif; font-size:14px; font-weight:700;
  letter-spacing:2px; cursor:pointer;
  transition:all .2s;
  box-shadow:0 4px 20px rgba(0,229,255,0.25);
  margin-bottom:12px;
}
.speak-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,229,255,0.35);}
.speak-btn:active{transform:translateY(0);}
.speak-btn:disabled{opacity:0.5;cursor:not-allowed;transform:none;}

.stop-btn{
  width:100%; padding:12px;
  background:transparent; border:1px solid rgba(255,80,80,0.4);
  border-radius:12px; color:#ff6060;
  font-family:'Orbitron',sans-serif; font-size:12px; font-weight:700;
  letter-spacing:2px; cursor:pointer; transition:all .2s;
  display:none;
}
.stop-btn:hover{background:rgba(255,80,80,0.1);}
.stop-btn.show{display:block;}

/* WAVEFORM */
.waveform{
  height:56px; margin:14px 0;
  display:flex; align-items:center; justify-content:center; gap:3px;
  opacity:0; transition:opacity .3s;
}
.waveform.active{opacity:1;}
.bar-w{
  width:4px; border-radius:2px;
  background:linear-gradient(180deg,var(--accent),var(--accent2));
  box-shadow:0 0 4px var(--accent);
  animation:wave .6s ease-in-out infinite;
  height:8px;
}
@keyframes wave{0%,100%{transform:scaleY(1)}50%{transform:scaleY(3)}}

/* STATUS */
.status{
  text-align:center; font-family:'Share Tech Mono',monospace;
  font-size:12px; color:var(--text2); letter-spacing:2px; margin-top:8px;
  min-height:18px;
}
.status.speaking{color:var(--green);}
.status.error{color:#ff6060;}

/* QUICK TEXTS */
.quick-label{
  font-size:10px; color:var(--text2); letter-spacing:2px;
  text-transform:uppercase; margin-bottom:8px; display:block; margin-top:20px;
}
.quick-btns{display:flex;flex-wrap:wrap;gap:8px;}
.q-btn{
  padding:6px 14px; background:var(--surface2);
  border:1px solid var(--border); border-radius:20px;
  color:var(--text2); font-size:12px; cursor:pointer;
  transition:all .18s; font-family:'Inter',sans-serif;
}
.q-btn:hover{border-color:var(--accent);color:var(--accent);}

/* DOWNLOAD SECTION */
.download-section{
  margin-top:20px;
  background:var(--surface2);
  border:1px solid rgba(0,230,118,0.2);
  border-radius:14px;
  padding:16px 18px;
}
.download-label{
  font-size:10px; color:var(--green); letter-spacing:2px;
  text-transform:uppercase; display:block; margin-bottom:10px;
  font-family:'Orbitron',sans-serif;
}
.download-info{
  font-size:12px; color:var(--text2); line-height:1.6;
  margin-bottom:12px;
}
.download-info a{color:var(--accent); text-decoration:none;}
.download-info a:hover{text-decoration:underline;}
.dl-btn{
  width:100%; padding:13px;
  background:linear-gradient(135deg,rgba(0,230,118,0.15),rgba(0,229,255,0.1));
  border:1px solid rgba(0,230,118,0.4);
  border-radius:10px; color:var(--green);
  font-family:'Orbitron',sans-serif; font-size:12px; font-weight:700;
  letter-spacing:2px; cursor:pointer; transition:all .2s;
}
.dl-btn:hover{background:rgba(0,230,118,0.2); box-shadow:0 0 16px rgba(0,230,118,0.2);}
.dl-btn:disabled{opacity:0.4; cursor:not-allowed;}
  .card{padding:24px 20px;}
  .controls{grid-template-columns:1fr;}

</style>
</head>
<body>

<div class="card">
  <div class="robot-head">
    <div class="robot-face" id="robotFace">
      <div class="robot-eyes">
        <div class="eye"></div>
        <div class="eye"></div>
      </div>
      <div class="robot-mouth" id="robotMouth"></div>
    </div>
    <div class="title">ROBO<span>VOICE</span></div>
    <div class="subtitle">Type It — Let the Robot Speak</div>
  </div>

  <label class="input-label">▸ Type your text here</label>
  <textarea id="textInput" placeholder="Enter your text here..."

Example: Namaste! Main aapka AI assistant hoon. Aaj ka din bahut acha hai!"></textarea>

  <div class="waveform" id="waveform">
    <div class="bar-w" style="animation-delay:0s"></div>
    <div class="bar-w" style="animation-delay:.05s"></div>
    <div class="bar-w" style="animation-delay:.10s"></div>
    <div class="bar-w" style="animation-delay:.15s"></div>
    <div class="bar-w" style="animation-delay:.20s"></div>
    <div class="bar-w" style="animation-delay:.25s"></div>
    <div class="bar-w" style="animation-delay:.30s"></div>
    <div class="bar-w" style="animation-delay:.25s"></div>
    <div class="bar-w" style="animation-delay:.20s"></div>
    <div class="bar-w" style="animation-delay:.15s"></div>
    <div class="bar-w" style="animation-delay:.10s"></div>
    <div class="bar-w" style="animation-delay:.05s"></div>
    <div class="bar-w" style="animation-delay:0s"></div>
  </div>

  <div class="controls">
    <div class="control-item">
      <label>Speed <span class="val" id="speedVal">0.8x</span></label>
      <input type="range" id="speedRange" min="0.3" max="1.5" step="0.1" value="0.8"
        oninput="document.getElementById('speedVal').textContent=this.value+'x'">
    </div>
    <div class="control-item">
      <label>Pitch <span class="val" id="pitchVal">0.6</span></label>
      <input type="range" id="pitchRange" min="0.1" max="1.0" step="0.05" value="0.6"
        oninput="document.getElementById('pitchVal').textContent=parseFloat(this.value).toFixed(2)">
    </div>
    <div class="control-item">
      <label>Volume <span class="val" id="volVal">1.0</span></label>
      <input type="range" id="volRange" min="0" max="1" step="0.05" value="1"
        oninput="document.getElementById('volVal').textContent=parseFloat(this.value).toFixed(1)">
    </div>
    <div class="control-item">
      <label>Voice</label>
      <select id="voiceSelect"><option>Loading voices...</option></select>
    </div>
  </div>

  <button class="speak-btn" id="speakBtn" onclick="speak()">🤖 Start ROBOT </button>
  <button class="stop-btn" id="stopBtn" onclick="stopSpeaking()">⏹ STOP</button>

  <div class="status" id="status">Ready —  Click the button to generate audio.</div>

  <span class="quick-label">⚡ Quick texts</span>
  <div class="quick-btns">
    <button class="q-btn" onclick="setQuick('Namaste! Main aapka AI robot hoon.')">Namaste</button>
    <button class="q-btn" onclick="setQuick('Welcome to Tech X! Aaj ka program shuru hota hai.')">Welcome</button>
    <button class="q-btn" onclick="setQuick('Sahi jawab! Bahut badiya. Aage badhte hain.')">Correct!</button>
    <button class="q-btn" onclick="setQuick('Galat jawab. Dobara koshish karo.')">Wrong!</button>
    <button class="q-btn" onclick="setQuick('Quiz shuru hone wala hai. Taiyaar ho jao!')">Quiz Start</button>
    <button class="q-btn" onclick="setQuick('Bahut shukriya! Aaj ka program yahan samapt hota hai.')">Thanks</button>
  </div>

  <!-- DOWNLOAD SECTION -->
  <div class="download-section">
    <span class="download-label">⬇ Audio Download</span>
    <div class="download-info">
      Browser ka built-in TTS directly download nahi hota. Neeche do options hain:<br>
      <strong style="color:var(--text)">Option 1:</strong> Upar "🤖 Robot Bolega" dabao → audio sun lo → phir <strong style="color:var(--accent)">Record</strong> button se record karo.<br>
      <strong style="color:var(--text)">Option 2:</strong> Free MP3 download ke liye text copy karo → 
      <a href="https://elevenlabs.io" target="_blank">ElevenLabs.io</a> ya 
      <a href="https://ttsmp3.com" target="_blank">ttsmp3.com</a> par paste karo.
    </div>
    <button class="dl-btn" id="recordBtn" onclick="toggleRecord()">🔴 RECORDING (Browser Mic)</button>
    <div class="status" id="recStatus" style="margin-top:8px;"></div>
  </div>   

</div>

<script>
var synth = window.speechSynthesis;
var voices = [];
var isSpeaking = false;

function loadVoices() {
  voices = synth.getVoices();
  var sel = document.getElementById('voiceSelect');
  sel.innerHTML = '';

  // prefer Hindi/Indian voices first
  var preferred = voices.filter(function(v){
    return v.lang.indexOf('hi') !== -1 || v.lang.indexOf('en-IN') !== -1;
  });
  var others = voices.filter(function(v){
    return v.lang.indexOf('hi') === -1 && v.lang.indexOf('en-IN') === -1;
  });
  var sorted = preferred.concat(others);

  if(sorted.length === 0){
    sel.innerHTML = '<option>No voices found</option>';
    return;
  }
  sorted.forEach(function(v, i){
    var opt = document.createElement('option');
    opt.value = voices.indexOf(v);
    opt.textContent = v.name + ' (' + v.lang + ')';
    if(v.lang.indexOf('hi') !== -1 && sel.selectedIndex === -1) sel.selectedIndex = i;
    sel.appendChild(opt);
  });
}

if(synth.onvoiceschanged !== undefined){
  synth.onvoiceschanged = loadVoices;
}
setTimeout(loadVoices, 300);

function speak() {
  var text = document.getElementById('textInput').value.trim();
  if(!text){ setStatus('⚠ Pehle text likho!', 'error'); return; }
  if(!voices.length){ loadVoices(); }

  synth.cancel();

  var utt = new SpeechSynthesisUtterance(text);
  utt.rate   = parseFloat(document.getElementById('speedRange').value);
  utt.pitch  = parseFloat(document.getElementById('pitchRange').value);
  utt.volume = parseFloat(document.getElementById('volRange').value);

  var selIdx = parseInt(document.getElementById('voiceSelect').value);
  if(!isNaN(selIdx) && voices[selIdx]) utt.voice = voices[selIdx];

  utt.onstart = function(){
    isSpeaking = true;
    document.getElementById('waveform').classList.add('active');
    document.getElementById('robotMouth').classList.add('speaking');
    document.getElementById('speakBtn').disabled = true;
    document.getElementById('stopBtn').classList.add('show');
    setStatus('🤖 BOL RAHA HAI...', 'speaking');
  };
  utt.onend = function(){
    isSpeaking = false;
    document.getElementById('waveform').classList.remove('active');
    document.getElementById('robotMouth').classList.remove('speaking');
    document.getElementById('speakBtn').disabled = false;
    document.getElementById('stopBtn').classList.remove('show');
    setStatus('✓ Complete — dobara bolne ke liye button dabao');
  };
  utt.onerror = function(){
    isSpeaking = false;
    document.getElementById('waveform').classList.remove('active');
    document.getElementById('robotMouth').classList.remove('speaking');
    document.getElementById('speakBtn').disabled = false;
    document.getElementById('stopBtn').classList.remove('show');
    setStatus('⚠ Error — browser TTS support check karo', 'error');
  };

  synth.speak(utt);
}

function stopSpeaking(){
  synth.cancel();
  isSpeaking = false;
  document.getElementById('waveform').classList.remove('active');
  document.getElementById('robotMouth').classList.remove('speaking');
  document.getElementById('speakBtn').disabled = false;
  document.getElementById('stopBtn').classList.remove('show');
  setStatus('⏹ Stopped');
}

function setStatus(msg, cls){
  var s = document.getElementById('status');
  s.textContent = msg;
  s.className = 'status' + (cls ? ' ' + cls : '');
}

function setQuick(text){
  document.getElementById('textInput').value = text;
}

/* ── RECORD & DOWNLOAD ── */
var mediaRecorder = null;
var audioChunks = [];
var isRecording = false;

function toggleRecord(){
  if(!isRecording){ startRecord(); } else { stopRecord(); }
}

function startRecord(){
  if(!navigator.mediaDevices){ setRecStatus('⚠ Mic not supported in this browser','error'); return; }
  navigator.mediaDevices.getUserMedia({audio:true}).then(function(stream){
    audioChunks = [];
    mediaRecorder = new MediaRecorder(stream);
    mediaRecorder.ondataavailable = function(e){ if(e.data.size>0) audioChunks.push(e.data); };
    mediaRecorder.onstop = function(){
      var blob = new Blob(audioChunks,{type:'audio/webm'});
      var url  = URL.createObjectURL(blob);
      var a    = document.createElement('a');
      a.href = url; a.download = 'robot-voice.webm';
      document.body.appendChild(a); a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      stream.getTracks().forEach(function(t){t.stop();});
      setRecStatus('✓ Download ho gaya! robot-voice.webm','ok');
      document.getElementById('recordBtn').textContent='🔴 RECORD KARO (Browser Mic)';
    };
    mediaRecorder.start();
    isRecording = true;
    document.getElementById('recordBtn').textContent='⏹ RECORDING... STOP KARO';
    document.getElementById('recordBtn').style.borderColor='rgba(255,80,80,0.6)';
    document.getElementById('recordBtn').style.color='#ff6060';
    setRecStatus('🔴 Recording chal rahi hai — pehle Robot Bolega dabao, phir Stop karo','speaking');
  }).catch(function(){
    setRecStatus('⚠ Mic permission do ya HTTPS use karo','error');
  });
}

function stopRecord(){
  if(mediaRecorder && mediaRecorder.state !== 'inactive'){ mediaRecorder.stop(); }
  isRecording = false;
  document.getElementById('recordBtn').style.borderColor='rgba(0,230,118,0.4)';
  document.getElementById('recordBtn').style.color='var(--green)';
}

function setRecStatus(msg, cls){
  var s = document.getElementById('recStatus');
  s.textContent = msg;
  s.className = 'status' + (cls==='error'?' error':cls==='speaking'?' speaking':cls==='ok'?' speaking':'');
}
</script>
</body>
</html>                                