<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Device Tracker</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap');
  :root {
    --bg: #0f1117;
    --surface: #181c27;
    --surface2: #1e2335;
    --border: rgba(255,255,255,0.08);
    --border2: rgba(255,255,255,0.14);
    --text: #f0f2f8;
    --muted: #8890a8;
    --accent: #4f8ef7;
    --accent2: #7c5af0;
    --green: #22c97a;
    --red: #f05a5a;
    --amber: #f0a422;
    --mono: 'DM Mono', monospace;
    --sans: 'DM Sans', sans-serif;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--sans); background: var(--bg); color: var(--text); min-height: 100vh; }

  /* NAV */
  .nav { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; background: var(--surface); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 100; }
  .nav-brand { font-size: 15px; font-weight: 700; letter-spacing: -0.3px; display: flex; align-items: center; gap: 8px; }
  .nav-brand span { background: var(--accent); color: #fff; border-radius: 6px; padding: 2px 8px; font-size: 12px; font-weight: 600; }
  .nav-tabs { display: flex; gap: 4px; }
  .nav-tab { padding: 7px 16px; border-radius: 8px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; background: transparent; color: var(--muted); transition: all 0.2s; }
  .nav-tab.active { background: var(--accent); color: #fff; }
  .nav-tab:hover:not(.active) { background: var(--surface2); color: var(--text); }

  /* PAGES */
  .page { display: none; padding: 24px; max-width: 960px; margin: 0 auto; }
  .page.active { display: block; }

  /* FORM PAGE */
  .form-hero { text-align: center; padding: 2rem 0 1.5rem; }
  .form-hero h1 { font-size: 26px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 6px; }
  .form-hero p { color: var(--muted); font-size: 14px; }
  .form-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 28px; max-width: 520px; margin: 0 auto; }
  .form-section { margin-bottom: 20px; }
  .form-label { font-size: 12px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 8px; display: block; }
  .form-input { width: 100%; padding: 11px 14px; background: var(--surface2); border: 1px solid var(--border2); border-radius: 10px; color: var(--text); font-family: var(--sans); font-size: 14px; outline: none; transition: border-color 0.2s; }
  .form-input:focus { border-color: var(--accent); }
  .form-input::placeholder { color: var(--muted); }
  .device-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .device-option { position: relative; }
  .device-option input[type=radio] { display: none; }
  .device-label { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 14px 8px; background: var(--surface2); border: 1px solid var(--border); border-radius: 12px; cursor: pointer; transition: all 0.2s; text-align: center; }
  .device-label:hover { border-color: var(--border2); }
  .device-option input:checked + .device-label { border-color: var(--accent); background: rgba(79,142,247,0.1); }
  .device-option input:disabled + .device-label { opacity: 0.35; cursor: not-allowed; }
  .device-icon { font-size: 26px; }
  .device-name { font-size: 11px; font-weight: 600; color: var(--text); }
  .device-id { font-size: 10px; color: var(--muted); font-family: var(--mono); }
  .device-status-badge { font-size: 9px; padding: 2px 6px; border-radius: 20px; font-weight: 600; margin-top: 2px; }
  .badge-free { background: rgba(34,201,122,0.15); color: var(--green); }
  .badge-taken { background: rgba(240,90,90,0.15); color: var(--red); }
  .submit-btn { width: 100%; padding: 13px; background: var(--accent); color: #fff; border: none; border-radius: 10px; font-family: var(--sans); font-size: 14px; font-weight: 700; cursor: pointer; transition: all 0.2s; margin-top: 4px; letter-spacing: 0.2px; }
  .submit-btn:hover { background: #3a7ae8; transform: translateY(-1px); }
  .submit-btn:active { transform: translateY(0); }
  .charger-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .charger-option { position: relative; }
  .charger-option input[type=checkbox] { display: none; }
  .charger-label { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 10px 6px; background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; cursor: pointer; transition: all 0.2s; text-align: center; }
  .charger-label:hover { border-color: var(--border2); }
  .charger-option input:checked + .charger-label { border-color: var(--amber); background: rgba(240,164,34,0.1); }
  .charger-option input:disabled + .charger-label { opacity: 0.35; cursor: not-allowed; }
  .charger-icon { font-size: 20px; }
  .charger-name { font-size: 11px; font-weight: 600; color: var(--text); }
  .charger-id { font-size: 10px; color: var(--muted); font-family: var(--mono); }
  .success-icon { font-size: 48px; margin-bottom: 12px; }
  .success-msg h2 { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
  .success-msg p { color: var(--muted); font-size: 13px; }
  .success-msg button { margin-top: 16px; padding: 10px 24px; background: var(--surface2); border: 1px solid var(--border2); border-radius: 8px; color: var(--text); font-family: var(--sans); font-size: 13px; cursor: pointer; }

  /* DASHBOARD PAGE */
  .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; flex-wrap: gap; }
  .dash-title { font-size: 20px; font-weight: 700; }
  .dash-sub { font-size: 13px; color: var(--muted); margin-top: 2px; }
  .clear-btn { padding: 8px 14px; background: rgba(240,90,90,0.12); border: 1px solid rgba(240,90,90,0.3); border-radius: 8px; color: var(--red); font-family: var(--sans); font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .clear-btn:hover { background: rgba(240,90,90,0.2); }
  .stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 20px; }
  .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; }
  .stat-label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .stat-val { font-size: 28px; font-weight: 700; }
  .stat-val.green { color: var(--green); }
  .stat-val.red { color: var(--red); }
  .stat-val.amber { color: var(--amber); }
  .devices-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; margin-bottom: 24px; }
  .device-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 18px; transition: border-color 0.2s; position: relative; overflow: hidden; }
  .device-card.taken { border-color: rgba(240,90,90,0.3); }
  .device-card.free { border-color: rgba(34,201,122,0.2); }
  .device-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; }
  .device-card.taken::before { background: var(--red); }
  .device-card.free::before { background: var(--green); }
  .dc-top { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
  .dc-icon { font-size: 30px; }
  .dc-meta { flex: 1; }
  .dc-name { font-size: 14px; font-weight: 700; }
  .dc-id { font-size: 11px; color: var(--muted); font-family: (--mono); }
  .dc-badge { font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .dc-badge.free { background: rgba(34,201,122,0.12); color: var(--green); border: 1px solid rgba(34,201,122,0.2); }
  .dc-badge.taken { background: rgba(240,90,90,0.12); color: var(--red); border: 1px solid rgba(240,90,90,0.2); }
  .dc-info { border-top: 1px solid var(--border); padding-top: 12px; display: flex; flex-direction: column; gap: 6px; }
  .dc-row { display: flex; align-items: flex-start; gap: 8px; font-size: 12px; }
  .dc-row-label { color: var(--muted); min-width: 70px; font-weight: 500; }
  .dc-row-val { color: var(--text); font-weight: 500; word-break: break-word; }
  .dc-row-val.phone { font-family: var(--mono); color: var(--accent); }
  .dc-empty { color: var(--muted); font-style: italic; }
  .return-btn { margin-top: 12px; width: 100%; padding: 8px; background: rgba(240,90,90,0.1); border: 1px solid rgba(240,90,90,0.25); border-radius: 8px; color: var(--red); font-family: var(--sans); font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .return-btn:hover { background: rgba(240,90,90,0.2); }
  .log-section { margin-top: 8px; }
  .log-title { font-size: 13px; font-weight: 700; color: var(--muted); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
  .log-table { width: 100%; border-collapse: collapse; font-size: 1var2px; }
  .log-table th { text-align: left; padding: 8px 12px; background: var(--surface); border-bottom: 1px solid var(--border); color: var(--muted); font-weight: 600; text-transform: uppercase; font-size: 11px; letter-spacing: 0.5px; }
  .log-table td { padding: 10px 12px; border-bottom: 1px solid var(--border); color: var(--text); vertical-align: top; }
  .log-table tr:last-child td { border-bottom: none; }
  .log-table tr:hover td { background: var(--surface2); }
  .log-badge { font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 20px; }
  .log-badge.out { background: rgba(240,90,90,0.12); color: var(--red); }
  .log-badge.returned { background: rgba(34,201,122,0.12); color: var(--green); }
  .log-empty { text-align: center; padding: 2rem; color: var(--muted); font-size: 13px; }
  .charger-dash-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; }
  .chr-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 14px; }
  .chr-card.chr-taken { border-color: rgba(240,164,34,0.35); }
  .chr-card.chr-free { border-color: rgba(34,201,122,0.2); }
  .chr-top { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
  .chr-ico { font-size: 22px; }
  .chr-meta { flex:1; }
  .chr-name { font-size: 13px; font-weight: 700; }
  .chr-id { font-size: 10px; color: var(--muted); font-family: var(--mono); }
  .chr-badge { font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 20px; }
  .chr-badge.free { background: rgba(34,201,122,0.12); color: var(--green); border:1px solid rgba(34,201,122,0.2); }
  .chr-badge.taken { background: rgba(240,164,34,0.12); color: var(--amber); border:1px solid rgba(240,164,34,0.3); }
  .chr-info { font-size: 12px; color: var(--muted); }
  .chr-info strong { color: var(--text); display: block; font-size: 12px; margin-bottom: 2px; }
  .chr-return { margin-top: 8px; width:100%; padding: 6px; background: rgba(240,164,34,0.1); border: 1px solid rgba(240,164,34,0.25); border-radius: 7px; color: var(--amber); font-family: var(--sans); font-size: 11px; font-weight: 600; cursor: pointer; transition: all 0.2s; }
  .chr-return:hover { background: rgba(240,164,34,0.2); }
  .toast { position: fixed; bottom: 24px; right: 24px; background: var(--surface); border: 1px solid var(--border2); border-radius: 10px; padding: 12px 18px; font-size: 13px; font-weight: 500; color: var(--text); transform: translateY(80px); opacity: 0; transition: all 0.3s; z-index: 999; }
  .toast.show { transform: translateY(0); opacity: 1; }
  @media(max-width:600px) {
    .stats-row { grid-template-columns: repeat(2,1fr); }
    .device-grid { grid-template-columns: repeat(2,1fr); }
    .charger-grid { grid-template-columns: repeat(2,1fr); }
    .charger-dash-grid { grid-template-columns: repeat(2,1fr); }
    .nav-brand span { display: none; }
    .page { padding: 16px; }
  }
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-brand">📦 DeviceTrack <span>Emergency</span></div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showPage('form')">📋 Take Device</button>
    <button class="nav-tab" onclick="showPage('dash')">📊 Dashboard</button>
  </div>
</nav>

<!-- FORM PAGE -->
<div class="page active" id="page-form">
  <div class="form-hero"> 
    <h1>Device Checkout</h1>
    <p>Fill in your details and select which device you are taking</p>
  </div>

  <div class="form-card" id="form-box">
    <div class="form-section">
      <label class="form-label">Your Full Name</label>
      <input class="form-input" id="f-name" type="text" placeholder="" />
    </div>

    <div class="form-section">

      <label class="form-label">Contact Number</label>
      <input class="form-input" id="f-phone" type="tel" placeholder="" maxlength="10" />
    </div>
    <div class="form-section">
      <label class="form-label">Your Location / Where you are going</label>
      <input class="form-input" id="f-location" type="text" placeholder="" />
    </div>
    <div class="form-section">
      <label class="form-label">Select Device</label>
      <div class="device-grid" id="device-grid"><!-- filled by JS --></div>
    </div>
    <div class="form-section">
      <label class="form-label">Purpose / Reason (optional)</label>
      <input class="form-input" id="f-purpose" type="text" placeholder="" />
    </div>
    <div class="form-section">
      <label class="form-label">🔌 Charger Le Raha Hai? (select karo)</label>
      <div class="charger-grid" id="charger-grid">
        <div class="charger-option">
          <input type="checkbox" id="chr-1" value="CHR-1">
          <label class="charger-label" for="chr-1"><span class="charger-icon">🔌</span><span class="charger-name">Charger 1</span><span class="charger-id">CHR-1</span><span id="chr-1-status" class="device-status-badge badge-free">🟢 Free</span></label>
        </div>
        <div class="charger-option">
          <input type="checkbox" id="chr-2" value="CHR-2">
          <label class="charger-label" for="chr-2"><span class="charger-icon">🔌</span><span class="charger-name">Charger 2</span><span class="charger-id">CHR-2</span><span id="chr-2-status" class="device-status-badge badge-free">🟢 Free</span></label>
        </div>
        <div class="charger-option">
          <input type="checkbox" id="chr-3" value="CHR-3">
          <label class="charger-label" for="chr-3"><span class="charger-icon">🔌</span><span class="charger-name">Charger 3</span><span class="charger-id">CHR-3</span><span id="chr-3-status" class="device-status-badge badge-free">🟢 Free</span></label>
        </div>

        <div class="charger-option">

          <input type="checkbox" id="chr-4" value="CHR-4">

          <label class="charger-label" for="chr-4"><span class="charger-icon">🔌</span><span class="charger-name">Charger 4</span><span class="charger-id">CHR-4</span><span id="chr-4-status" class="device-status-badge badge-free">🟢 Free</span></label>
          
        </div>
      </div>
    </div>
    <button class="submit-btn" onclick="submitForm()">✅ Confirm Checkout</button>
  </div>

  <div class="success-msg" id="success-box">
    <div class="success-icon">✅</div>
    <h2>Device Checked Out!</h2>
    <p id="success-text">—</p>
    <button onclick="resetForm()">Take Another Device</button>
  </div>
</div>

<!-- DASHBOARD PAGE -->
<div class="page" id="page-dash">
  <div class="dash-header">
    <div>
      <div class="dash-title">📊 Device Dashboard</div>
      <div class="dash-sub" id="dash-time">Loading...</div>
    </div>
    <button class="clear-btn" onclick="clearAll()">🗑 Clear All Logs</button>
  </div>

  <div class="stats-row">
    <div class="stat-card"><div class="stat-label">Total Devices</div><div class="stat-val" id="s-total">0</div></div>
    <div class="stat-card"><div class="stat-label">Available</div><div class="stat-val green" id="s-free">0</div></div>
    <div class="stat-card"><div class="stat-label">Checked Out</div><div class="stat-val red" id="s-taken">0</div></div>
    <div class="stat-card"><div class="stat-label">🔌 Chargers Free</div><div class="stat-val amber" id="s-chargers">4</div></div>
  </div>

  <div class="devices-grid" id="devices-grid"><!-- filled by JS --></div>

  <div class="log-section" style="margin-bottom:20px">
    <div class="log-title">🔌 Charger Status</div>
    <div class="charger-dash-grid" id="charger-dash-grid"></div>
  </div>

  <div class="log-section">
    <div class="log-title">📜 Activity Log</div>
    <table class="log-table">
      <thead><tr>
        <th>Device</th><th>Person</th><th>Contact</th><th>Location</th><th>Charger</th><th>Time</th><th>Status</th><th></th>
      </tr></thead>
      <tbody id="log-body"><tr><td colspan="6" class="log-empty">No activity yet.</td></tr></tbody>
    </table>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ---- Device definitions ----
const DEVICES = [
  { id: 'TAB-1', name: 'Tab 1',  icon: '📲', type: 'tab' },
  { id: 'TAB-2', name: 'Tab 2',  icon: '📲', type: 'tab' },
  { id: 'TAB-3', name: 'Tab 3',  icon: '📲', type: 'tab' },
  { id: 'TAB-4', name: 'Tab 4',  icon: '📲', type: 'tab' },
  { id: 'LAP-1', name: 'Laptop', icon: '💻', type: 'laptop' },
  { id: 'PHN-1', name: 'Phone',  icon: '📞', type: 'phone' },
];

// ---- State ----
function getState() {
  try { return JSON.parse(localStorage.getItem('dt_state')) || { assignments: {}, chargers: {}, log: [] }; }
  catch(e) { return { assignments: {}, chargers: {}, log: [] }; }
}
function saveState(s) { localStorage.setItem('dt_state', JSON.stringify(s)); }

// ---- Page switch ----
function showPage(p) {
  document.querySelectorAll('.page').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(el => el.classList.remove('active'));
  document.getElementById('page-' + p).classList.add('active');
  document.querySelectorAll('.nav-tab')[p === 'form' ? 0 : 1].classList.add('active');
  if (p === 'form') buildFormDevices();
  if (p === 'dash') buildDash();
}

// ---- FORM ----
function buildFormDevices() {
  const state = getState();
  const grid = document.getElementById('device-grid');
  grid.innerHTML = DEVICES.map(d => {
    const taken = !!state.assignments[d.id];
    return `
      <div class="device-option">
        <input type="radio" name="device" id="dev-${d.id}" value="${d.id}" ${taken ? 'disabled' : ''}>
        <label class="device-label" for="dev-${d.id}">
          <span class="device-icon">${d.icon}</span>
          <span class="device-name">${d.name}</span>
          <span class="device-id">${d.id}</span>
          <span class="device-status-badge ${taken ? 'badge-taken' : 'badge-free'}">${taken ? '🔴 Taken' : '🟢 Free'}</span>
        </label>
      </div>`;
  }).join('');
  // update charger statuses
  ['CHR-1','CHR-2','CHR-3','CHR-4'].forEach(cid => {
    const cb = document.getElementById(cid.toLowerCase().replace('-','-'));
    const el = document.getElementById(cid.toLowerCase().replace('chr-','chr-') + '-status');
    const taken = !!(state.chargers && state.chargers[cid]);
    const cbEl = document.getElementById('chr-' + cid.split('-')[1]);
    const stEl = document.getElementById('chr-' + cid.split('-')[1] + '-status');
    if (cbEl) cbEl.disabled = taken;
    if (stEl) { stEl.textContent = taken ? '🔴 Taken' : '🟢 Free'; stEl.className = 'device-status-badge ' + (taken ? 'badge-taken' : 'badge-free'); }
  });
}

function submitForm() {
  const name = document.getElementById('f-name').value.trim();
  const phone = document.getElementById('f-phone').value.trim();
  const location = document.getElementById('f-location').value.trim();
  const purpose = document.getElementById('f-purpose').value.trim();
  const deviceRadio = document.querySelector('input[name="device"]:checked');

  if (!name) { toast('⚠ Please enter your name'); return; }
  if (!phone) { toast('⚠ Please enter contact number'); return; }
  if (!location) { toast('⚠ Please enter your location'); return; }
  if (!deviceRadio) { toast('⚠ Please select a device'); return; }

  const deviceId = deviceRadio.value;
  const state = getState();
  if (state.assignments[deviceId]) { toast('⚠ This device is already taken!'); return; }

  // collect checked chargers
  const checkedChargers = ['CHR-1','CHR-2','CHR-3','CHR-4'].filter(cid => {
    const cb = document.getElementById('chr-' + cid.split('-')[1]);
    return cb && cb.checked && !cb.disabled;
  });

  const now = new Date();
  const timeStr = now.toLocaleString('en-IN', { dateStyle: 'short', timeStyle: 'short' });

  if (!state.chargers) state.chargers = {};
  state.assignments[deviceId] = { name, phone, location, purpose, time: timeStr, chargers: checkedChargers };
  checkedChargers.forEach(cid => { state.chargers[cid] = { name, phone, time: timeStr }; });
  state.log.unshift({ deviceId, name, phone, location, purpose, time: timeStr, status: 'out', chargers: checkedChargers });
  saveState(state);

  const dev = DEVICES.find(d => d.id === deviceId);
  const chrTxt = checkedChargers.length ? ` + ${checkedChargers.join(', ')}` : '';
  document.getElementById('success-text').textContent = `${dev.icon} ${dev.name} (${deviceId})${chrTxt} is now with ${name} at ${location}`;
  document.getElementById('form-box').style.display = 'none';
  document.getElementById('success-box').style.display = 'block';
  toast('✅ Device checked out successfully!');
}

function resetForm() {
  document.getElementById('f-name').value = '';
  document.getElementById('f-phone').value = '';
  document.getElementById('f-location').value = '';
  document.getElementById('f-purpose').value = '';
  ['1','2','3','4'].forEach(n => { const cb = document.getElementById('chr-'+n); if(cb) cb.checked = false; });
  document.getElementById('form-box').style.display = 'block';
  document.getElementById('success-box').style.display = 'none';
  buildFormDevices();
}

// ---- DASHBOARD ----
function buildDash() {
  const state = getState();
  const now = new Date().toLocaleString('en-IN', { dateStyle: 'full', timeStyle: 'short' });
  document.getElementById('dash-time').textContent = now;

  const total = DEVICES.length;
  const takenCount = Object.keys(state.assignments).length;
  const freeCount = total - takenCount;

  document.getElementById('s-total').textContent = total;
  document.getElementById('s-free').textContent = freeCount;
  document.getElementById('s-taken').textContent = takenCount;
  const chrTaken = Object.keys(state.chargers || {}).length;
  document.getElementById('s-chargers').textContent = (4 - chrTaken);

  // Device cards
  const grid = document.getElementById('devices-grid');
  grid.innerHTML = DEVICES.map(d => {
    const a = state.assignments[d.id];
    if (a) {
      return `
        <div class="device-card taken">
          <div class="dc-top">
            <span class="dc-icon">${d.icon}</span>
            <div class="dc-meta">
              <div class="dc-name">${d.name}</div>
              <div class="dc-id">${d.id}</div>
            </div>
            <span class="dc-badge taken">Checked Out</span>
          </div>
          <div class="dc-info">
            <div class="dc-row"><span class="dc-row-label">👤 Person</span><span class="dc-row-val">${a.name}</span></div>
            <div class="dc-row"><span class="dc-row-label">📞 Contact</span><span class="dc-row-val phone">${a.phone}</span></div>
            <div class="dc-row"><span class="dc-row-label">📍 Location</span><span class="dc-row-val">${a.location}</span></div>
            ${a.purpose ? `<div class="dc-row"><span class="dc-row-label">📝 Purpose</span><span class="dc-row-val">${a.purpose}</span></div>` : ''}
            <div class="dc-row"><span class="dc-row-label">🕐 Time</span><span class="dc-row-val">${a.time}</span></div>
          </div>
          <button class="return-btn" onclick="returnDevice('${d.id}')">↩ Mark as Returned</button>
        </div>`;
    } else {
      return `
        <div class="device-card free">
          <div class="dc-top">
            <span class="dc-icon">${d.icon}</span>
            <div class="dc-meta">
              <div class="dc-name">${d.name}</div>
              <div class="dc-id">${d.id}</div>
            </div>
            <span class="dc-badge free">Available</span>
          </div>
          <div class="dc-info">
            <div class="dc-row"><span class="dc-empty">No one has taken this device</span></div>
          </div>
        </div>`;
    }
  }).join('');

  // Charger cards
  const CHARGERS = [{id:'CHR-1',n:'Charger 1'},{id:'CHR-2',n:'Charger 2'},{id:'CHR-3',n:'Charger 3'},{id:'CHR-4',n:'Charger 4'}];
  const cdash = document.getElementById('charger-dash-grid');
  cdash.innerHTML = CHARGERS.map(c => {
    const a = (state.chargers||{})[c.id];
    return a ? `
      <div class="chr-card chr-taken">
        <div class="chr-top"><span class="chr-ico">🔌</span><div class="chr-meta"><div class="chr-name">${c.n}</div><div class="chr-id">${c.id}</div></div><span class="chr-badge taken">Out</span></div>
        <div class="chr-info"><strong>${a.name}</strong>${a.phone} · ${a.time}</div>
        <button class="chr-return" onclick="returnCharger('${c.id}')">↩ Return</button>
      </div>` : `
      <div class="chr-card chr-free">
        <div class="chr-top"><span class="chr-ico">🔌</span><div class="chr-meta"><div class="chr-name">${c.n}</div><div class="chr-id">${c.id}</div></div><span class="chr-badge free">Free</span></div>
        <div class="chr-info" style="color:var(--muted); font-style:italic">Available</div>
      </div>`;
  }).join('');

  // Log
  const tbody = document.getElementById('log-body');
  if (!state.log.length) {
    tbody.innerHTML = '<tr><td colspan="8" class="log-empty">No activity yet.</td></tr>';
    return;
  }
  const dev = (id) => DEVICES.find(d => d.id === id);
  tbody.innerHTML = state.log.map((l, i) => `
    <tr>
      <td>${dev(l.deviceId) ? dev(l.deviceId).icon : ''} <strong>${l.deviceId}</strong></td>
      <td>${l.name}</td>
      <td style="font-family:var(--mono); color:var(--accent)">${l.phone}</td>
      <td>${l.location}</td>
      <td style="color:var(--amber)">${(l.chargers && l.chargers.length) ? l.chargers.join(', ') : '—'}</td>
      <td style="color:var(--muted)">${l.time}</td>
      <td><span class="log-badge ${l.status}">${l.status === 'out' ? '🔴 Out' : '🟢 Returned'}</span></td>
      <td><button onclick="deleteLog(${i})" style="background:rgba(240,90,90,0.12);border:1px solid rgba(240,90,90,0.3);border-radius:6px;color:var(--red);padding:3px 10px;font-size:11px;font-weight:600;cursor:pointer;">🗑 Delete</button></td>
    </tr>`).join('');
}

function returnDevice(id) {
  const state = getState();
  if (!state.assignments[id]) return;
  const a = state.assignments[id];
  const now = new Date().toLocaleString('en-IN', { dateStyle: 'short', timeStyle: 'short' });
  state.log.unshift({ deviceId: id, name: a.name, phone: a.phone, location: a.location, time: now, status: 'returned' });
  if (a.chargers && state.chargers) a.chargers.forEach(cid => { delete state.chargers[cid]; });
  delete state.assignments[id];
  saveState(state);
  buildDash();
  toast('✅ Device marked as returned');
}

function returnCharger(cid) {
  const state = getState();
  if (!state.chargers[cid]) return;
  delete state.chargers[cid];
  saveState(state);
  buildDash();
  toast('✅ Charger returned');
}

function deleteLog(i) {
  const state = getState();
  state.log.splice(i, 1);
  saveState(state);
  buildDash();
  toast('🗑 Entry deleted');
}

function clearAll() {
  if (!confirm('Clear all logs and assignments?')) return;
  localStorage.removeItem('dt_state');
  buildDash();
  toast('🗑 All data cleared');
}

function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ---- Init ----
buildFormDevices();
setInterval(() => {
  const active = document.getElementById('page-dash').classList.contains('active');
  if (active) document.getElementById('dash-time').textContent = new Date().toLocaleString('en-IN', { dateStyle: 'full', timeStyle: 'short' });
}, 60000);
</script>
</body>
</html>       

