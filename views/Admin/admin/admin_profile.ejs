<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Quiz App</title>

<style>

body {
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(135deg, #4cbaeb, #2c3e50);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  margin: 0;
}

/* HEADING */
.main-heading {
  position: absolute;
  top: 12px;
  width: 100%;
  text-align: center;
  font-size: 42px;
  font-weight: bold;
  color: #ffffff;
  letter-spacing: 5px;
  text-shadow: 0 0 10px #00c3ff, 0 0 20px #00c3ff;
}

/* QUIZ BOX */
.quiz-box {
  position: relative;   /* 🔥 IMPORTANT */
  background: #fff;
  padding: 52px;
  width: 717px;
  height: 308px;
  border-radius: 12px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
}

h2 {
  margin-bottom: 46px;
}

/* FLASH INSIDE BOX */
#flash {
  position: absolute;   /* 🔥 changed from fixed */
  top: 10px;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  padding: 10px;
  border-radius: 6px;
  text-align: center;
  font-weight: bold;
  color: white;
  display: none;
  opacity: 0;
  transition: opacity 0.5s ease;
  font-size: 18px;
}

.correct-msg { background: #2ecc71; }
.wrong-msg { background: #d73421; }

/* OPTIONS */
.options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 27px;
}

.option {
  background: #f1f1f1;
  padding: 12px;
  border-radius: 6px;
  cursor: pointer;
  transition: 0.3s;
  display: flex;
  align-items: center;
  font-weight: 500;
}

.option:hover { background: #ddd; }

.option span {
  font-weight: bold;
  margin-right: 8px;
}

.option.disabled {
  pointer-events: none;
  opacity: 0.5;
}

button {
  margin-top: 62px;
  padding: 16px;
  width: 24%;
  border: none;
  background: #3498db;
  color: white;
  border-radius: 6px;
  cursor: pointer;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

button:hover { background: #2980b9; }

</style>
</head>

<body>

<h1 class="main-heading">techX Spark</h1>

<div class="quiz-box">
  <div id="flash"></div> <!-- 🔥 moved inside -->
  <h2 id="question"></h2>
  <div id="options"></div>
  <button onclick="nextQuestion()">Next</button>
</div>

<script>

const quiz = [
 {q:"Which MS Office app is used to make slides?", options:["Word","Excel","PowerPoint","OneNote"], answer:2},
 {q:"In Excel, what does =SUM(A1:A5) do?", options:["Multiplies numbers","Adds numbers","Subtracts numbers","Finds average"], answer:1},
 {q:"Maximum number of slides in a single PowerPoint presentation?", options:["500","10,000","50,000","Unlimited"], answer:3},
 {q:"Which is the oldest Microsoft Office program?", options:["Word","Excel","PowerPoint","Outlook"], answer:0},
 {q:"Who is known as the “Father of Computers”?", options:["Steve Jobs","Charles Babbage","Bill Gates","Alan Turing"], answer:1}
];

let current = 0;
let score = 0;
let answered = false;

function loadQuestion() {
  answered = false;

  let q = quiz[current];
  document.getElementById("question").innerText = `Q${current + 1}. ${q.q}`;

  let labels = ["A", "B", "C", "D"];
  let html = '<div class="options-grid">';

  q.options.forEach((opt, i) => {
    html += `
      <div class="option" onclick="selectAnswer(${i})">
        <span>${labels[i]}.</span> ${opt}
      </div>`;
  });

  html += '</div>';
  document.getElementById("options").innerHTML = html;
}

function showFlash(message, type) {
  let flash = document.getElementById("flash");

  flash.innerHTML = message;
  flash.className = type;
  flash.style.display = "block";

  setTimeout(() => { flash.style.opacity = "1"; }, 10);

  setTimeout(() => {
    flash.style.opacity = "0";
    setTimeout(() => { flash.style.display = "none"; }, 500);
  }, 2000);
}

function selectAnswer(index) {
  let options = document.querySelectorAll(".option");

  if (answered) return;

  if (index === quiz[current].answer) {
    score++;
    answered = true;
    showFlash("✅ Correct Answer!", "correct-msg");
    options.forEach(opt => opt.classList.add("disabled"));
  } else {
    options[index].classList.add("disabled");
    showFlash("❌ Wrong Answer! Try Again", "wrong-msg");
  }
}

function nextQuestion() {
  if (!answered) {
    showFlash("⚠️ First select correct answer!", "wrong-msg");
    return;
  }

  current++;

  if (current < quiz.length) {
    loadQuestion();
  } else {
    document.querySelector(".quiz-box").innerHTML =
      `<h2>Your Score: ${score}/${quiz.length}</h2>
       <button onclick="location.reload()">Restart</button>`;
  }
}

loadQuestion();

</script>

</body>
</html>

<style>
  /* 📱 MOBILE VIEW */
@media (max-width: 768px) {

  body {
    align-items: flex-start;   /* top ton start */
    padding-top: 60px;
  }

  .quiz-box {
    width: 100%;        /* full width */
    height: 100vh;      /* full screen height */
    border-radius: 0;   /* remove rounded corners */
    padding: 20px;
  }

  h2 {
    font-size: 20px;
    margin-bottom: 20px;
  }

  .options-grid {
    grid-template-columns: 1fr;   /* 1 column (better for phone) */
    gap: 15px;
  }

  button {
    width: 80%;
    margin-top: 30px;
  }

  #flash {
    font-size: 16px;
    width: 90%;
  }

  .main-heading {
    font-size: 24px;
    letter-spacing: 2px;
  }
}

</style>