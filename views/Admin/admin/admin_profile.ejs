<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Quiz App</title>

<style>

body {
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(135deg, #4cbaeb, #2c3e50);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  margin: 0;
}

/* INTRO SCREEN */
.intro-screen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: black;
  color: #00ffcc;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 50px;
  font-weight: bold;
  letter-spacing: 5px;
  text-shadow: 0 0 20px #00ffcc;
}

/* HEADING */
.main-heading {
  position: absolute;
  top: 12px;
  width: 100%;
  text-align: center;
  font-size: 42px;
  font-weight: bold;
  color: #ffffff;
}

/* QUIZ BOX */
.quiz-box {
  position: relative;
  background: #fff;
  padding: 52px;
  width: 717px;
  height: 308px;
  border-radius: 12px;
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  display: none; /* hidden initially */
}

h2 { margin-bottom: 46px; }

/* FLASH */
#flash {
  position: absolute;
  top: 10px;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  padding: 10px;
  border-radius: 6px;
  text-align: center;
  font-weight: bold;
  color: white;
  display: none;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.correct-msg { background: #2ecc71; }
.wrong-msg { background: #d73421; }

/* OPTIONS */
.options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.option {
  background: #f1f1f1;
  padding: 12px;
  border-radius: 6px;
  cursor: pointer;
}

.option:hover { background: #ddd; }

.option.disabled {
  pointer-events: none;
  opacity: 0.5;
}

/* BUTTON */
button {
  margin-top: 40px;
  padding: 12px;
  width: 40%;
  background: #3498db;
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

button:hover { background: #2980b9; }

/* 📱 MOBILE */
@media (max-width: 768px) {
  .quiz-box {
    width: 100%;
    height: 100vh;
    border-radius: 0;
    padding: 20px;
  }

  .options-grid {
    grid-template-columns: 1fr;
  }

  button { width: 80%; }
}

</style>
</head>

<body>

<!-- INTRO -->
<div id="intro" class="intro-screen"></div>

<h1 class="main-heading">techX Spark</h1>

<!-- QUIZ -->
<div class="quiz-box">
  <div id="flash"></div>
  <h2 id="question"></h2>
  <div id="options"></div>
  <button onclick="nextQuestion()">Next</button>
</div>

<script>

const quiz = [
 {q:"Which MS Office app is used to make slides?", options:["Word","Excel","PowerPoint","OneNote"], answer:2},
 {q:"In Excel, what does =SUM(A1:A5) do?", options:["Multiplies numbers","Adds numbers","Subtracts numbers","Finds average"], answer:1},
 {q:"Maximum number of slides in a single PowerPoint presentation?", options:["500","10,000","50,000","Unlimited"], answer:3}, {q:"Which is the oldest Microsoft Office program?", options:["Word","Excel","PowerPoint","Outlook"], answer:0}, 
 {q:"Who is known as the “Father of Computers”?", options:["Steve Jobs","Charles Babbage","Bill Gates","Alan Turing"], answer:1},
 {q:"What does “Alt + Tab” do?", options:["Opens Task Manager","Switches between open applications","Closes the current window","Opens a new tab in browser"], answer:1},
 {q:"What does “AI” stand for?", options:["Automated Internet","Artificial Intelligence","Algorithmic Input","Active Interface"], answer:1}, 
 {q:"ChatGPT is an example of which type of AI?", options:["Narrow AI","General AI","Super AI","Quantum AI"], answer:0},
 {q:"In Excel, what does the formula =AVERAGE(A1:A10) do?", options:["Adds numbers","Finds the middle number","Finds the average","Multiplies numbers"], answer:2},
 {q:"What does Ctrl + Z mean in office life?", options:["Save file","Undo mistake","Go home early","Restart boss"], answer:1},
 {q:"What is cloud storage?", options:["Files in sky","Files on internet servers","Data in weather system","USB in airplane"], answer:1},
 {q:"Why did Excel break up with Word?", options:["No formula for love","Too many pages","PowerPoint interference","Missing file"], answer:0}, 
 {q:"What does AI do best in offices today?", options:["Write drafts","Summarize data","Automate repetitive tasks","All of the above"], answer:3}, 
 {q:"Why does laptop become hot sometimes?", options:["It is angry","Processor is working hard","Keyboard friction","Too many emails"], answer:1},
 {q:"Why do people keep many file names like Final_v2_Final_Last?", options:["Creativity","Forgot original version","Office tradition","All of the above"], answer:3}, 
 {q:"What is the full form of COMPUTER?", options:["Common Operating Machine Particularly Used for Technical Education and Research","Central Output Machine Processing User Terminal","Control Output Memory Program Understanding Technology Electronic Resource","Common Online Machine Providing Useful Technology Education Router"], answer:0},
];

let current = 0;
let score = 0;
let answered = false;

/* INTRO ANIMATION */
function startIntro() {
  let text = "Welcome to techX Spark";
  let i = 0;
  let intro = document.getElementById("intro");

  function type() {
    if (i < text.length) {
      intro.innerHTML += text.charAt(i);
      i++;
      setTimeout(type, 250);
    } else {
      setTimeout(() => {
        intro.style.display = "none";
        document.querySelector(".quiz-box").style.display = "block";
        loadQuestion();
      }, 1000);
    }
  }

  type();
}

/* LOAD QUESTION */
function loadQuestion() {
  answered = false;
  let q = quiz[current];

  document.getElementById("question").innerText =
    `Q${current + 1}. ${q.q}`;

  let html = '<div class="options-grid">';
  q.options.forEach((opt, i) => {
    html += `<div class="option" onclick="selectAnswer(${i})">${opt}</div>`;
  });
  html += '</div>';

  document.getElementById("options").innerHTML = html;
}

/* FLASH */
function showFlash(msg, type) {
  let flash = document.getElementById("flash");
  flash.innerHTML = msg;
  flash.className = type;
  flash.style.display = "block";
  flash.style.opacity = "1";

  setTimeout(() => {
    flash.style.opacity = "0";
    setTimeout(() => flash.style.display = "none", 500);
  }, 1500);
}

/* SELECT */
function selectAnswer(i) {
  if (answered) return;

  if (i === quiz[current].answer) {
    score++;
    answered = true;
    showFlash("✅ Correct", "correct-msg");
  } else {
    showFlash("❌ Wrong", "wrong-msg");
  }
}

/* NEXT */
function nextQuestion() {
  if (!answered) {
    showFlash("⚠️ Select correct answer first", "wrong-msg");
    return;
  }

  current++;

  if (current < quiz.length) {
    loadQuestion();
  } else {
    document.querySelector(".quiz-box").innerHTML =
    `
    <h2 style="text-align:center;">🎉 Thank You! 🎉</h2>
    <p style="text-align:center;">You completed the quiz 😊</p>
    <div style="text-align:center; font-size:40px;">🎊 🎈 🙌</div>
    <button onclick="location.reload()">Restart</button>
    `;
  }
}

/* START */
startIntro();

</script>

</body>
</html>