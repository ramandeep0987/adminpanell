<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>techstar</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'DM Sans',sans-serif; background:#d3bea4; min-height:100vh; display:flex; align-items:center; justify-content:center; overflow:hidden; }
body::before { content:''; position:fixed; top:-180px; right:-180px; width:420px; height:420px; border-radius:50%; background:radial-gradient(circle,#ffe0b2 0%,#ffcc80 60%,transparent 100%); opacity:0.55; pointer-events:none; z-index:0; }
body::after { content:''; position:fixed; bottom:-160px; left:-140px; width:340px; height:340px; border-radius:50%; background:radial-gradient(circle,#b3e5fc 0%,#81d4fa 60%,transparent 100%); opacity:0.5; pointer-events:none; z-index:0; }

#intro { position:fixed; inset:0; z-index:100; background:#1a1a2e; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:16px; }
.intro-brand { font-family:'Syne',sans-serif; font-weight:800; font-size:clamp(48px,8vw,80px); letter-spacing:-2px; color:#2196f3; }
.intro-brand span { color:#fff; }
#introTyped { font-family:'DM Sans',sans-serif; font-size:clamp(16px,2.5vw,22px); color:#94a3b8; letter-spacing:1px; min-height:32px; }
.cursor { display:inline-block; width:2px; height:1.1em; background:#f59e0b; margin-left:3px; vertical-align:middle; animation:blink .65s steps(1) infinite; }
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

#spinnerScreen { position:fixed; inset:0; z-index:90; background:#1a1a2e; display:none; flex-direction:column; align-items:center; justify-content:center; gap:24px; }
.spin-dial { width:320px; height:320px; border-radius:50%; background:conic-gradient(#f59e0b 0deg,#ef4444 90deg,#8b5cf6 180deg,#06b6d4 270deg,#f59e0b 360deg); display:flex; align-items:center; justify-content:center; cursor:pointer; position:relative; transition:transform 0.15s; }
.spin-dial:hover { transform:scale(1.04); }
.spin-dial.disabled-dial { cursor:not-allowed; pointer-events:none; opacity:0.85; }
.spin-dial::after { content:''; position:absolute; inset:12px; border-radius:50%; background:#1a1a2e; }
.spin-inner { position:relative; z-index:2; text-align:center; }
.spin-number { font-family:'Verdana',Geneva,sans-serif; font-weight:700; font-size:80px; color:#fff; line-height:1; position:relative; display:inline-block; }
.spin-tap { font-size:11px; color:#64748b; letter-spacing:3px; text-transform:uppercase; margin-top:4px; }
.tap-icon-wrap { position:relative; width:100px; height:100px; display:flex; align-items:center; justify-content:center; margin:0 auto; }
.tap-ring { position:absolute; width:70px; height:70px; border-radius:50%; border:3px solid #ffe0b2; animation:tapPulse 1.6s ease-out infinite; }
.tap-ring.delay { animation-delay:0.8s; }
.tap-emoji { position:relative; z-index:2; font-size:56px; line-height:1; filter:drop-shadow(0 4px 10px rgba(0,0,0,0.35)); animation:tapBounce 1.6s ease-in-out infinite; }
@keyframes tapPulse { 0%{ transform:scale(0.5); opacity:0.9; } 100%{ transform:scale(1.6); opacity:0; } }
@keyframes tapBounce { 0%,100%{ transform:translateY(0) scale(1); } 45%{ transform:translateY(4px) scale(0.92); } 55%{ transform:translateY(4px) scale(0.92); } 80%{ transform:translateY(0) scale(1); } }
@keyframes dialSpin { to { transform:rotate(360deg); } }
.spinning { animation:dialSpin 1.2s linear infinite; }

.main-heading { position:fixed; top:20px; left:0; right:0; text-align:center; z-index:10; pointer-events:none; }
.main-heading span { font-family:'Syne',sans-serif; font-weight:800; font-size:clamp(20px,3vw,28px); background:linear-gradient(135deg,#1a1a2e,#374151); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }

.game-wrapper { display:none; align-items:stretch; gap:16px; margin-top:60px; position:relative; z-index:1; }

.lifeline-panel { width:326px; flex-shrink:0; background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.10); padding:0 0 24px; position:relative; overflow:hidden; display:flex; flex-direction:column; }
.lifeline-panel::before { content:''; position:absolute; top:0; left:0; right:0; height:5px; background:linear-gradient(90deg,#8b5cf6,#06b6d4); }
.lifeline-panel-title { font-family:verdana; font-weight:800; font-size:19px; letter-spacing:2px; text-transform:uppercase; color:#1a1a2e; text-align:center; padding:22px 16px 14px; border-bottom:1px solid #f1f5f9; margin-bottom:16px; }
.lifeline-hint { margin:0 16px 18px; background:#fffbeb; border:1.5px solid #fde68a; border-radius:10px; padding:10px 13px; font-size:16px; font-weight:500; color:#92400e; line-height:1.55; text-align:center; }
.choice-btn { display:flex; align-items:center; gap:8px; width:calc(100% - 32px); margin:0 16px 12px; padding:15px 14px; background:#e2effc; border:1.5px solid #8b8c8c; border-radius:12px; cursor:pointer; font-size:15px; font-weight:600; color:#000; font-family:'DM Sans',sans-serif; transition:all .18s; text-align:left; }
.choice-btn:last-of-type { margin-bottom:0; }
.choice-btn:hover { background:#fef3c7; border-color:#f59e0b; color:#d97706; transform:translateX(3px); }
.choice-btn.used { background:#f1f5f9; border-color:#e2e8f0; color:#cbd5e1; cursor:not-allowed; pointer-events:none; opacity:0.55; }

.quiz-box { background:#fff; border-radius:24px; width:min(680px,96vw); padding:36px 40px 32px; box-shadow:0 8px 40px rgba(0,0,0,0.10),0 1px 0 rgba(0,0,0,0.04); position:relative; overflow:hidden; }
.quiz-box::before { content:''; position:absolute; top:0; left:0; right:0; height:5px; background:linear-gradient(90deg,#f59e0b,#ef4444,#8b5cf6,#06b6d4); z-index:1; }

.prog-row { display:flex; align-items:center; gap:12px; margin-bottom:22px; }
.prog-track { flex:1; height:5px; background:#ebf1f7; border-radius:3px; overflow:hidden; }
.prog-fill { height:100%; border-radius:3px; background:linear-gradient(90deg,#f59e0b,#ef4444); transition:width .5s ease; }
.prog-text { font-size:12px; font-weight:600; color:#94a3b8; letter-spacing:.5px; white-space:nowrap; }

.q-chip { display:inline-block; background:#fef3c7; color:#d97706; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:4px 12px; border-radius:20px; margin-bottom:10px; }
#question { font-family:'verdana'; font-weight:700; font-size:clamp(15px,2vw,19px); color:#1a1a2e; line-height:1.5; margin-bottom:22px; }

#flash { background:#fef9c3; border:2px solid #fde047; color:#854d0e; border-radius:14px; padding:16px 20px; font-size:18px; font-weight:700; text-align:center; margin-bottom:16px; display:none; letter-spacing:0.3px; line-height:1.4; }
#flash.correct-msg { background:#dcfce7; border-color:#86efac; color:#166534; }
#flash.wrong-msg   { background:#fee2e2; border-color:#fca5a5; color:#991b1b; }

.options-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:16px; }
@media(max-width:480px){ .options-grid{ grid-template-columns:1fr; } }

.option { background:#e2effc; border:1.5px solid #8b8c8c; padding:13px 14px; border-radius:14px; cursor:pointer; font-size:14px; font-weight:500; color:#000; display:flex; align-items:center; gap:10px; transition:all .18s; }
.option:hover { border-color:#f59e0b; background:#fffbeb; color:#1a1a2e; transform:translateY(-2px); box-shadow:0 4px 12px rgba(245,158,11,.15); }
.option-letter { width:28px; height:28px; border-radius:8px; flex-shrink:0; background:#a9ceff; color:#393939; font-size:18px; font-weight:700; display:flex; align-items:center; justify-content:center; transition:all .18s; }
.option:hover .option-letter { background:#f59e0b; color:#fff; }
.option.correct { border-color:#22c55e !important; background:#f0fdf4 !important; color:#166634 !important; transform:none; }
.option.correct .option-letter { background:#22c55e; color:#fff; }
.option.wrong { border-color:#ef4444 !important; background:#fef2f2 !important; }
.option.wrong .option-letter { background:#ef4444; color:#fff; }
.option.disabled { cursor:default; pointer-events:none; }
.option.hidden { visibility:hidden; pointer-events:none; }

.next-btn-wrap { text-align:center; margin-top:14px; }
.next-btn { display:inline-block; padding:15px 270px; background:linear-gradient(135deg,#f59e0b,#ef4444); color:#fff; border:none; border-radius:50px; font-family:'Syne',sans-serif; font-size:13px; font-weight:700; letter-spacing:1px; cursor:pointer; transition:all .2s; box-shadow:0 4px 16px rgba(245,158,11,.3); }
.next-btn:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(245,158,11,.4); }
.next-btn:active { transform:translateY(0); }

.end-wrap { text-align:center; padding:8px 0; }
.end-trophy { font-size:64px; margin-bottom:16px; }
.end-title { font-family:'Syne',sans-serif; font-weight:800; font-size:32px; color:#1a1a2e; margin-bottom:6px; }
.end-sub { font-size:15px; color:#64748b; margin-bottom:28px; }
.end-score { font-family:'Syne',sans-serif; font-weight:800; font-size:72px; line-height:1; background:linear-gradient(135deg,#f59e0b,#ef4444); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.end-of { font-size:14px; color:#94a3b8; margin-top:4px; letter-spacing:1px; }
.restart-btn { margin-top:32px; display:inline-block; padding:14px 48px; background:#1a1a2e; color:#fff; border:none; border-radius:14px; font-family:'Syne',sans-serif; font-size:15px; font-weight:700; cursor:pointer; letter-spacing:1px; transition:all .2s; }
.restart-btn:hover { background:#374151; transform:translateY(-2px); }

@media(max-width:700px){
  .game-wrapper { flex-direction:column; align-items:stretch; }
  .lifeline-panel { width:100%; }
  .lifeline-panel-title { padding:14px 16px 12px; font-size:15px; }
  .choice-btn { width:calc(50% - 24px); display:inline-flex; margin:0 8px 10px; }
}
</style>
</head>
<body>

<div id="intro">
  <div class="intro-brand">tech<span>X</span></div>
  <div id="introTyped"><span class="cursor"></span></div>
</div>

<div id="spinnerScreen">
  <div class="spin-dial" id="spinDial" onclick="startSpin()">
    <div class="spin-inner">
      <div class="spin-number" id="spinNumber">
        <div class="tap-icon-wrap" id="tapIconWrap">
          <div class="tap-ring"></div>
          <div class="tap-ring delay"></div>
          <span class="tap-emoji">👆</span>
        </div>
      </div>
      <div class="spin-tap">tap</div>
    </div>
  </div>
</div>

<div class="main-heading"><span>techstar</span></div>

<div class="game-wrapper" id="gameWrapper">
  <div class="lifeline-panel">
    <div class="lifeline-panel-title">Lifelines</div>
    
    <div style="flex:1;display:flex;flex-direction:column;justify-content:center;">
      <button class="choice-btn" id="btn-poll" onclick="useAudiencePoll(this)">🕵️ Expert Advice</button>
      <div style="height:16px;"></div>
      <button class="choice-btn" id="btn-5050" onclick="use5050(this)">⚖️ 50 : 50</button>
    </div>
  </div>


  <div class="quiz-box" id="quizBox">
    <div class="prog-row">
      <div class="prog-track"><div class="prog-fill" id="progFill" style="width:0%"></div></div>
      <div class="prog-text" id="progText">1 / 16</div>
    </div>
    <div id="flash"></div>
    <div class="q-chip" id="qChip">Question 01</div>
    <h2 id="question"></h2>
    <div id="options"></div>
    <div class="next-btn-wrap"><button class="next-btn" onclick="nextQuestion()">Next →</button></div>
  </div>
</div>

<script>
/* ══════════════════════════════════════════
   CONFETTI  — DOM div based, no canvas needed
   Works in all browsers incl. VS Code Live Preview
══════════════════════════════════════════ */
var CONF_COLORS = ['#f59e0b','#22c55e','#ef4444','#8b5cf6','#06b6d4','#f97316','#ec4899','#ffd700','#a3e635','#38bdf8','#fb7185','#c084fc'];

function showConfetti() {
  var total = 150;
  var W = window.innerWidth;
  var H = window.innerHeight;

  for (var i = 0; i < total; i++) {
    (function() {
      var el = document.createElement('div');
      var isCircle = Math.random() > 0.5;
      var size = Math.random() * 10 + 6;
      var color = CONF_COLORS[Math.floor(Math.random() * CONF_COLORS.length)];

      /* random start position across full width, top portion of screen */
      var startX = Math.random() * W;
      var startY = -20;

      /* random horizontal drift and fall speed */
      var driftX  = (Math.random() - 0.5) * 300;
      var fallY   = H + 60;
      var dur     = (Math.random() * 2000 + 1500) + 'ms';
      var delay   = (Math.random() * 800) + 'ms';
      var rot     = Math.random() * 720 - 360;

      el.style.cssText = [
        'position:fixed',
        'pointer-events:none',
        'z-index:9999',
        'width:' + size + 'px',
        'height:' + (isCircle ? size : size * 1.6) + 'px',
        'background:' + color,
        'border-radius:' + (isCircle ? '50%' : '2px'),
        'left:' + startX + 'px',
        'top:' + startY + 'px',
        'opacity:1',
        'transition:none'
      ].join(';');

      document.body.appendChild(el);

      /* force reflow so transition fires */
      el.getBoundingClientRect();

      el.style.transition = 'transform ' + dur + ' ' + delay + ' cubic-bezier(0.25,0.46,0.45,0.94), opacity ' + dur + ' ' + delay + ' ease-in';
      el.style.transform  = 'translate(' + driftX + 'px, ' + fallY + 'px) rotate(' + rot + 'deg)';
      el.style.opacity    = '0';

      var removeAfter = parseFloat(dur) + parseFloat(delay) + 200;
      setTimeout(function() {
        if (el.parentNode) el.parentNode.removeChild(el);
      }, removeAfter);
    })();
  }
}

/* ══════════════════════════════
   SPIN TICK SOUND — synthesized, no audio file needed
══════════════════════════════ */
var audioCtx = null;
function getAudioCtx(){
  if(!audioCtx){
    try{ audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }catch(e){ return null; }
  }
  if(audioCtx.state === 'suspended'){ audioCtx.resume(); }
  return audioCtx;
}
function playTick(){
  var ctx = getAudioCtx();
  if(!ctx) return;
  var osc = ctx.createOscillator();
  var gain = ctx.createGain();
  osc.type = 'square';
  osc.frequency.setValueAtTime(700, ctx.currentTime);
  gain.gain.setValueAtTime(0.08, ctx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.06);
  osc.connect(gain);
  gain.connect(ctx.destination);
  osc.start(ctx.currentTime);
  osc.stop(ctx.currentTime + 0.06);
}
function playStopChime(){
  var ctx = getAudioCtx();
  if(!ctx) return;
  var osc = ctx.createOscillator();
  var gain = ctx.createGain();
  osc.type = 'triangle';
  osc.frequency.setValueAtTime(880, ctx.currentTime);
  osc.frequency.exponentialRampToValueAtTime(440, ctx.currentTime + 0.25);
  gain.gain.setValueAtTime(0.12, ctx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.3);
  osc.connect(gain);
  gain.connect(ctx.destination);
  osc.start(ctx.currentTime);
  osc.stop(ctx.currentTime + 0.3);
}
function playExpertSound(){
  var ctx = getAudioCtx();
  if(!ctx) return;
  var freqs = [523.25, 659.25, 783.99]; // C5, E5, G5 - curious "insight" arpeggio
  freqs.forEach(function(f, idx){
    var osc = ctx.createOscillator();
    var gain = ctx.createGain();
    osc.type = 'sine';
    var t = ctx.currentTime + idx * 0.09;
    osc.frequency.setValueAtTime(f, t);
    gain.gain.setValueAtTime(0.001, t);
    gain.gain.linearRampToValueAtTime(0.14, t + 0.02);
    gain.gain.exponentialRampToValueAtTime(0.001, t + 0.28);
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.start(t);
    osc.stop(t + 0.3);
  });
}
function play5050Sound(){
  var ctx = getAudioCtx();
  if(!ctx) return;
  [0, 0.1].forEach(function(delay){
    var osc = ctx.createOscillator();
    var gain = ctx.createGain();
    osc.type = 'square';
    var t = ctx.currentTime + delay;
    osc.frequency.setValueAtTime(500, t);
    osc.frequency.exponentialRampToValueAtTime(300, t + 0.12);
    gain.gain.setValueAtTime(0.1, t);
    gain.gain.exponentialRampToValueAtTime(0.001, t + 0.15);
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.start(t);
    osc.stop(t + 0.15);
  });
}
function playNextSound(){
  var ctx = getAudioCtx();
  if(!ctx) return;
  var osc = ctx.createOscillator();
  var gain = ctx.createGain();
  osc.type = 'sine';
  osc.frequency.setValueAtTime(400, ctx.currentTime);
  osc.frequency.exponentialRampToValueAtTime(900, ctx.currentTime + 0.18);
  gain.gain.setValueAtTime(0.1, ctx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.2);
  osc.connect(gain);
  gain.connect(ctx.destination);
  osc.start(ctx.currentTime);
  osc.stop(ctx.currentTime + 0.2);
}
function playClapBurst(ctx, t){
  /* one clap = filtered noise burst */
  var bufSize = Math.floor(ctx.sampleRate * 0.09);
  var buffer = ctx.createBuffer(1, bufSize, ctx.sampleRate);
  var data = buffer.getChannelData(0);
  for(var i=0;i<bufSize;i++){
    data[i] = (Math.random()*2-1) * Math.pow(1 - i/bufSize, 2);
  }
  var noise = ctx.createBufferSource();
  noise.buffer = buffer;
  var bp = ctx.createBiquadFilter();
  bp.type = 'bandpass';
  bp.frequency.value = 1800 + Math.random()*800;
  bp.Q.value = 0.8;
  var gain = ctx.createGain();
  gain.gain.setValueAtTime(0.25, t);
  gain.gain.exponentialRampToValueAtTime(0.001, t + 0.09);
  noise.connect(bp);
  bp.connect(gain);
  gain.connect(ctx.destination);
  noise.start(t);
  noise.stop(t + 0.09);
}
function playClapSound(){
  var ctx = getAudioCtx();
  if(!ctx) return;
  /* quick scattered claps then a little flourish, like applause */
  var hits = [0, 0.08, 0.15, 0.19, 0.28, 0.34, 0.4, 0.47, 0.55, 0.6, 0.68, 0.75];
  hits.forEach(function(delay){
    playClapBurst(ctx, ctx.currentTime + delay);
  });
  /* cheerful rising chime on top */
  [659.25, 783.99, 987.77].forEach(function(f, idx){
    var osc = ctx.createOscillator();
    var gain = ctx.createGain();
    osc.type = 'sine';
    var t = ctx.currentTime + 0.05 + idx*0.08;
    osc.frequency.setValueAtTime(f, t);
    gain.gain.setValueAtTime(0.001, t);
    gain.gain.linearRampToValueAtTime(0.12, t+0.02);
    gain.gain.exponentialRampToValueAtTime(0.001, t+0.35);
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.start(t);
    osc.stop(t+0.35);
  });
}
function playSadSound(){
  var ctx = getAudioCtx();
  if(!ctx) return;
  /* descending "wah wah wah" sad trombone */
  var notes = [392.00, 349.23, 329.63, 293.66]; // G4, F4, E4, D4
  notes.forEach(function(f, idx){
    var osc = ctx.createOscillator();
    var gain = ctx.createGain();
    osc.type = 'sawtooth';
    var t = ctx.currentTime + idx*0.22;
    osc.frequency.setValueAtTime(f, t);
    osc.frequency.exponentialRampToValueAtTime(f*0.94, t+0.2);
    gain.gain.setValueAtTime(0.001, t);
    gain.gain.linearRampToValueAtTime(0.11, t+0.03);
    gain.gain.exponentialRampToValueAtTime(0.001, t+0.22);
    osc.connect(gain);
    gain.connect(ctx.destination);
    osc.start(t);
    osc.stop(t+0.22);
  });
}

/* ══════════════════════════════
   VOICE — speaks the spin number out loud
══════════════════════════════ */
var voicesReady = false;
if ('speechSynthesis' in window) {
  window.speechSynthesis.onvoiceschanged = function(){ voicesReady = true; };
}
function speakNumber(n){
  try{
    if(!('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    var msg = new SpeechSynthesisUtterance(String(n));
    msg.lang = 'en-IN';
    msg.rate = 0.95;
    msg.pitch = 1;
    window.speechSynthesis.speak(msg);
  }catch(e){}
}
/* unlock speech synthesis on first user tap (needed on some mobile browsers) */
document.addEventListener('click', function unlockSpeech(){
  if('speechSynthesis' in window){
    var u = new SpeechSynthesisUtterance('');
    window.speechSynthesis.speak(u);
  }
  document.removeEventListener('click', unlockSpeech);
}, {once:true});

/* ══════════════════════════════
   QUIZ
══════════════════════════════ */
var quiz=[
  {q:"Which MS Office app is used to make slides?",options:["Word","Excel","PowerPoint","OneNote"],answer:2},
  {q:"In Excel, what does =SUM(A1:A5) do?",options:["Multiplies numbers","Adds numbers","Subtracts numbers","Finds average"],answer:1},
  {q:"Why does the printer fail when urgent work starts?",options:["Senses fear","Paper jam probability rises","Timing issue","Ancient office curse"],answer:1},
  {q:"Which is the oldest Microsoft Office program?",options:["Word","Excel","PowerPoint","Outlook"],answer:0},


   {q:"What does AI stand for?",options:["Automated Internet","Artificial Intelligence","Algorithmic Input","Active Interface"],answer:1},

  {q:"Who is known as the Father of Computers?",options:["Steve Jobs","Charles Babbage","Bill Gates","Alan Turing"],answer:1},
  {q:"What does Alt + Tab do?",options:["Opens Task Manager","Switches between open applications","Closes the current window","Opens a new tab in browser"],answer:1},
 
  {q:"ChatGPT is an example of which type of AI?",options:["Narrow AI","General AI","Super AI","Quantum AI"],answer:0},
 
 
  {q:"In Excel, what does =AVERAGE(A1:A10) do?",options:["Adds numbers","Finds the middle number","Finds the average","Multiplies numbers"],answer:2},

  {q:"Maximum number of slides in a single PowerPoint presentation? ",options:["500","10,000","50,000","Unlimited"],answer:3},


  {q:"What does Ctrl + Z mean in office life?",options:["Save file","Undo ","Go home early","Redo"],answer:1},
  {q:"What is cloud storage?",options:["Files in sky","Files on internet servers","Data in weather system","USB in airplane"],answer:1},
 
  
  {q:"What does AI do best in offices today?",options:["Write drafts","Summarize data","Automate repetitive tasks","All of the above"],answer:3},
  {q:"Why does laptop become hot sometimes?",options:["It is angry","Processor is working hard","Keyboard friction","Too many emails"],answer:1},
  {q:"Why do people keep many file names like Final_v2_Final_Last?",options:["Creativity","Forgot original version","Office tradition","All of the above"],answer:3},
  {q:"What is the full form of COMPUTER?",options:["Common Operating Machine Particularly Used for Technical Education and Research","Central Output Machine Processing User Terminal","Control Output Memory Program Understanding Technology Electronic Resource","Common Online Machine Providing Useful Technology Education Router"],answer:0},
];
var letters=['A','B','C','D'];
var current=0,score=0,answered=false,pollUsed=false,fiftyUsed=false,spinLocked=false;

function startIntro(){
  var text="Welcome to techstar 😊"; var i=0;
  var el=document.getElementById("introTyped");
  el.innerHTML='<span class="cursor"></span>';
  function type(){
    if(i<text.length){el.innerHTML=text.slice(0,i+1)+'<span class="cursor"></span>';i++;setTimeout(type,80);}
    else{setTimeout(function(){
      document.getElementById("intro").style.cssText="opacity:0;transition:opacity .5s";
      setTimeout(function(){document.getElementById("intro").style.display="none";showSpinner();},500);
    },900);}
  }
  type();
} 
function showSpinner(){
  spinLocked=false;
  var dial=document.getElementById("spinDial");
  dial.classList.remove('disabled-dial');
  document.getElementById("spinNumber").innerHTML='<div class="tap-icon-wrap" id="tapIconWrap"><div class="tap-ring"></div><div class="tap-ring delay"></div><span class="tap-emoji">👆</span></div>';
  document.getElementById("spinnerScreen").style.display="flex";
}
function startSpin(){
  if(spinLocked)return;
  var dial=document.getElementById("spinDial"),num=document.getElementById("spinNumber");
  if(dial.classList.contains('spinning'))return;
  spinLocked=true;
  dial.classList.add("spinning","disabled-dial");var count=1;
  getAudioCtx();
  var iv=setInterval(function(){num.textContent=count;count=count>30?1:count+1;playTick();},120);
  setTimeout(function(){
    clearInterval(iv);dial.classList.remove("spinning");playStopChime();
    if(quiz[current].q.indexOf("Why does the printer fail") !== -1){
      num.textContent = 9;
    } else if(quiz[current].q.indexOf("What does AI stand for") !== -1){
      num.textContent = 10;
    } else {
      num.textContent = Math.floor(Math.random()*30)+1;
    }
    speakNumber(num.textContent);
    var cd=5;var tap=dial.querySelector('.spin-tap');tap.textContent=cd;
    var ci=setInterval(function(){
      cd--;tap.textContent=cd;
      if(cd<=0){clearInterval(ci);tap.textContent='tap';document.getElementById("spinnerScreen").style.display="none";document.getElementById("gameWrapper").style.display="flex";loadQuestion();}
    },1000);
  },Math.random()*2000+2000);
}
function loadQuestion(){
  answered=false;pollUsed=false;fiftyUsed=false;
  var q=quiz[current];
  document.getElementById("progFill").style.width=Math.round((current/quiz.length)*100)+"%";
  document.getElementById("progText").textContent=(current+1)+" / "+quiz.length;
  document.getElementById("qChip").textContent="Question "+String(current+1).padStart(2,'0');
  document.getElementById("question").textContent=q.q;
  var flash=document.getElementById("flash");flash.style.display="none";flash.className="";
  document.getElementById('btn-poll').className='choice-btn'+(pollUsed?' used':'');
  document.getElementById('btn-5050').className='choice-btn'+(fiftyUsed?' used':'');
  var html='<div class="options-grid">';
  q.options.forEach(function(opt,i){html+='<div class="option" id="opt'+i+'" onclick="selectAnswer('+i+')">'+'<div class="option-letter">'+letters[i]+'</div><span>'+opt+'</span></div>';});
  html+='</div>';
  document.getElementById("options").innerHTML=html;
}
var flashTimer = null;
function showFlash(msg,cls){
  if(flashTimer){ clearTimeout(flashTimer); flashTimer=null; }
  var f=document.getElementById("flash");
  f.textContent=msg; f.className=cls; f.style.display="block";
  flashTimer = setTimeout(function(){f.style.display="none";f.className=""; flashTimer=null;},3000);
}
function selectAnswer(i){
  if(answered)return;
  if(i===quiz[current].answer){
    score++;answered=true;
    document.querySelectorAll('.option').forEach(function(o){o.classList.add('disabled');});
    document.getElementById("opt"+i).classList.add("correct");
    showFlash("🎉 You cracked it!","correct-msg");
    playClapSound();
    showConfetti();
  } else {
    document.getElementById("opt"+i).classList.add("wrong");
    showFlash("🐧 That answer slipped on the ice.","wrong-msg");
    playSadSound();
    setTimeout(function(){document.getElementById("opt"+i).classList.remove("wrong");},3000);
  }
}
function useAudiencePoll(btn){
  if(pollUsed||answered)return;
  pollUsed=true; btn.className='choice-btn used';
  playExpertSound();
  var correct=quiz[current].answer;
  var opts=quiz[current].options;
  showFlash("🕵️ Let's hear from our expert!");
}
function use5050(btn){
  if(fiftyUsed||answered)return; fiftyUsed=true; btn.className='choice-btn used';
  play5050Sound();
  var correct=quiz[current].answer;
  [0,1,2,3].filter(function(x){return x!==correct;}).sort(function(){return Math.random()-.5;}).slice(0,2).forEach(function(i){
    var el=document.getElementById("opt"+i);if(el)el.classList.add('hidden','disabled');
  });
  showFlash("⚖️ Two wrong options removed! Now choose wisely.","correct-msg");
}
function nextQuestion(){
  if(!answered){showFlash("⚠️ Select the correct answer first!","wrong-msg");return;}
  playNextSound();
  current++;
  if(current<quiz.length){
    document.getElementById("gameWrapper").style.display="none";
    document.getElementById("spinDial").classList.remove("spinning");
    showSpinner();
  } else {
    document.getElementById("gameWrapper").innerHTML='<div class="quiz-box" style="width:min(680px,96vw)"><div class="end-wrap"><div class="end-title">Thanks</div></div></div>';
    showConfetti();
  }
}
startIntro();
</script>
</body>
</html>