<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Quiz App</title>

<style>

body {
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(135deg, #4cbaeb, #2c3e50);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  margin: 0;
}

/* INTRO */
.intro-screen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: black;
  color: #00ffcc;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 50px;
}

/* 🔥 SPINNER */
.spinner-screen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #000000d9;
  display: none;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  color: white;
}

.spinner-wheel {
  width: 180px;
  height: 180px;
  border-radius: 50%;
  border: 10px solid #00ffcc;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40px;
  cursor: pointer;
  box-shadow: 0 0 30px #00ffcc;
}

.spin {
  animation: spin 0.1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* HEADING */
.main-heading {
  position: absolute;
  top: 12px;
  width: 100%;
  text-align: center;
  font-size: 42px;
  color: #fff;
}

/* QUIZ BOX */
.quiz-box {
  position: relative;
  background: #fff;
  padding: 52px;
  width: 717px;
  height: 308px;
  border-radius: 12px;
  display: none;
}

/* FLASH */
#flash {
  position: absolute;
  top: 10px;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  padding: 10px;
  border-radius: 6px;
  text-align: center;
  color: white;
  display: none;
}

.correct-msg { background: #2ecc71; }
.wrong-msg { background: #d73421; }

.options-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.option {
  background: #f1f1f1;
  padding: 12px;
  border-radius: 6px;
  cursor: pointer;
}

button {
  margin-top: 40px;
  padding: 12px;
  width: 40%;
  background: #3498db;
  color: white;
  border: none;
  border-radius: 6px;
  cursor: pointer;
}

</style>
</head>

<body>

<!-- INTRO -->
<div id="intro" class="intro-screen"></div>

<!-- 🔥 SPINNER -->
<div id="spinnerScreen" class="spinner-screen">
  <div class="spinner-wheel" onclick="startSpin()">🎯</div>
  <h2 id="spinNumber">Click to Spin</h2>
</div>

<h1 class="main-heading">techX Spark</h1>

<div class="quiz-box">
  <div id="flash"></div>
  <h2 id="question"></h2>
  <div id="options"></div>
  <button onclick="nextQuestion()">Next</button>
</div>

<script>

const quiz = [
 {q:"Which MS Office app is used to make slides?", options:["Word","Excel","PowerPoint","OneNote"], answer:2},
 {q:"In Excel, what does =SUM(A1:A5) do?", options:["Multiplies numbers","Adds numbers","Subtracts numbers","Finds average"], answer:1}
];

let current = 0;
let score = 0;
let answered = false;

/* INTRO */
function startIntro() {
  let text = "Welcome to techX Spark 😊";
  let i = 0;
  let intro = document.getElementById("intro");

  function type() {
    if (i < text.length) {
      intro.innerHTML += text.charAt(i);
      i++;
      setTimeout(type, 200);
    } else {
      setTimeout(() => {
        intro.style.display = "none";
        showSpinner();
      }, 800);
    }
  }
  type();
}

/* 🔥 SHOW SPINNER */
function showSpinner() {
  document.getElementById("spinnerScreen").style.display = "flex";
}

/* 🔥 SPIN LOGIC */
function startSpin() {
  let wheel = document.querySelector(".spinner-wheel");
  let text = document.getElementById("spinNumber");

  wheel.classList.add("spin");

  let count = 1;

  let interval = setInterval(() => {
    text.innerText = count;
    count++;
    if (count > 30) count = 1;
  }, 50);

  let stopTime = Math.random() * 2000 + 2000;

  setTimeout(() => {
    clearInterval(interval);
    wheel.classList.remove("spin");

    let final = Math.floor(Math.random() * 30) + 1;
    text.innerText = final;

    setTimeout(() => {
      document.getElementById("spinnerScreen").style.display = "none";
      document.querySelector(".quiz-box").style.display = "block";
      loadQuestion();
    }, 800);

  }, stopTime);
}

/* LOAD QUESTION (NO CHANGE) */
function loadQuestion() {
  answered = false;

  let q = quiz[current];
  document.getElementById("question").innerText =
    `Q${current + 1}. ${q.q}`;

  let html = '<div class="options-grid">';
  q.options.forEach((opt, i) => {
    html += `<div class="option" onclick="selectAnswer(${i})">${opt}</div>`;
  });
  html += '</div>';

  document.getElementById("options").innerHTML = html;
}

/* FLASH */
function showFlash(msg, type) {
  let flash = document.getElementById("flash");
  flash.innerHTML = msg;
  flash.className = type;
  flash.style.display = "block";

  setTimeout(() => flash.style.display = "none", 1500);
}

/* SELECT */
function selectAnswer(i) {
  if (answered) return;

  if (i === quiz[current].answer) {
    score++;
    answered = true;
    showFlash("✅ Correct", "correct-msg");
  } else {
    showFlash("❌ Wrong", "wrong-msg");
  }
}

/* NEXT (ONLY ADD SPINNER HERE) */
function nextQuestion() {
  if (!answered) {
    showFlash("⚠️ Select correct answer first", "wrong-msg");
    return;
  }

  current++;

  if (current < quiz.length) {
    document.querySelector(".quiz-box").style.display = "none";
    showSpinner();   // 🔥 spinner before next question
  } else {
    document.querySelector(".quiz-box").innerHTML =
    `
    <h2 style="text-align:center;">🎉 Thank You! 🎉</h2>
    <button onclick="location.reload()">Restart</button>
    `;
  }
}

/* START */
startIntro();

</script>

</body>
</html>


   