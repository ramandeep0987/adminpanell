<!DOCTYPE html>
<html>
  <head>
    <title>DMC&H</title>

   <style>
body {
  margin: 0;
  padding: 0;
  background: #f0ebf8;
  font-family: "Segoe UI", sans-serif;
}

.form-container {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 60px;
}

.form-card {
  width: 500px;
  background: #06508c;
  padding: 40px 35px;
  border-radius: 8px;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.logo-center {
  list-style: none;
  text-align: center;
  margin-bottom: 15px;
  padding: 0;
}

.big_img {
  width: 105px;   /* Logo size chhota */
  height: auto;
}

.form-card h2 {
  text-align: center;
  margin-bottom: 17px;
  font-weight: 500;
  color: white;
}

.form-group {
  margin-bottom: 25px;
}

.form-group label {
  display: block;
  margin-bottom: 8px;
  font-size: 18px;
  color: white;
}

.form-group input {
  width: 100%;
  padding: 10px;
  margin-bottom: 15px;
  border: none;
  border-bottom: 2px solid #ccc;
  font-size: 14px;
  outline: none;
  transition: 0.3s;
}

.form-group input:focus {
  border-bottom: 2px solid #673ab7;
}

.btn-submit {
  display: block;
  margin: 0 auto;   /* Button center */
  width: 40%;
  padding: 12px;
  border: none;
  background: #21145070;
  color: white;
  font-size: 15px;
  border-radius: 5px;
  cursor: pointer;
  transition: 0.3s;
}

.btn-submit:hover {
  background: #5a32a3;
}

</style>

  </head>

