        <div class="form-group">
          <label>Patient Name / ਮਰੀਜ਼ ਦਾ ਨਾਮ</label>
          <input type="text" placeholder="Enter Name" />

           <label>MRD Number / ਐਮ.ਆਰ.ਡੀ. ਨੰਬਰ</label>
          <input type="number" placeholder="Enter MRD" />

          <label>Phone Number / ਫੋਨ ਨੰਬਰ</label>
          <input type="number" placeholder="Enter Phone Number" />


         <label>Date Of Admission / ਦਾਖਲੇ ਦੀ ਤਾਰੀਖ</label>
<input type="date" id="todayDate" class="form-control" />

<script>
  document.getElementById("todayDate").valueAsDate = new Date();
</script>



       
<br><br>

          <label>Please indicate the floor of your ward / room?</label>

<select class="form-select" name="wardRoom" required>
  <option value="" disabled selected>select Option.</option>
  <option value="Ward-101">Groung Floor</option>
  <option value="Ward-102">First Floor</option>
  <option value="Ward-103">Second Floor</option>
  <option value="Room-201">Third Floor</option>
  <option value="Room-202">Fourth Floor</option>
 
</select>

<br><br><br>


<label>Ward / Department</label>

<select class="form-select" name="wardRoom" id="wardSelect" onchange="showInputBox()" required>
  <option value="" disabled selected>Select Option</option>
  <option value="Ward">Ward</option>
  <option value="Private Room">Private Room</option>
  <option value="ICU">ICU</option>
  <option value="Emergency">Emergency</option>
</select>

<!-- Hidden Input Field -->
<div id="customInputDiv" style="display:none; margin-top:10px;">
    <label> Patient location Details (Ward No./Room No./Bed No.) / ਮਰੀਜ਼ ਦੇ ਟਿਕਾਣੇ ਦੀ ਜਾਣਕਾਰੀ (ਵਾਰਡ ਨੰਬਰ / ਕਮਰਾ ਨੰਬਰ / ਬਿਸਤਰਾ ਨੰਬਰ) </label>
  <input type="text" class="form-control" placeholder="Enter details here">
</div>

<script>
  function showInputBox() {
    var select = document.getElementById("wardSelect");
    var inputDiv = document.getElementById("customInputDiv");

    if (select.value !== "") {
      inputDiv.style.display = "block";
    } else {
      inputDiv.style.display = "none";
    }
  }
</script>

