</head>

<body>

<div class="quiz-box">
  <h2>Quiz App</h2>

  <!-- ✅ FLASH MESSAGE -->
  <div id="flashMsg"></div>

  <div id="question"></div>
  <div id="options"></div>

  <button class="btn" onclick="nextQuestion()">Next</button>
</div>

<script>

const quiz = [
  {q:"Capital of India?", options:["Delhi","Mumbai","Chennai","Kolkata"], answer:0},
  {q:"2 + 2 = ?", options:["3","4","5","6"], answer:1},
  {q:"Sun rises from?", options:["West","North","East","South"], answer:2},
  {q:"HTML stands for?", options:["Hyper Text Markup Language","Hot Mail","How to Make","None"], answer:0},
  {q:"CSS used for?", options:["Styling","Database","Server","Logic"], answer:0},
  {q:"JS is?", options:["Language","Framework","Library","None"], answer:0},
  {q:"5 x 3 = ?", options:["8","15","10","20"], answer:1},
  {q:"Water formula?", options:["H2O","CO2","O2","NaCl"], answer:0},
  {q:"Earth is?", options:["Planet","Star","Moon","Gas"], answer:0},
  {q:"Which is programming?", options:["Java","HTML","CSS","All"], answer:3}
];

let index = 0;
let score = 0;
let answeredCorrect = false;

function loadQuestion() {
  answeredCorrect = false;

  document.getElementById("question").innerText = quiz[index].q;

  let html = "";
  quiz[index].options.forEach((opt, i) => {
    html += `<div class="option" onclick="checkAnswer(${i}, this)">${opt}</div>`;
  });

  document.getElementById("options").innerHTML = html;
}

function showFlash(message, type) {
  let flash = document.getElementById("flashMsg");

  flash.innerText = message;
  flash.className = "";

  if (type === "success") {
    flash.classList.add("flash-success");
  } else {
    flash.classList.add("flash-error");
  }

  flash.style.display = "block";

  setTimeout(() => {
    flash.style.display = "none";
  }, 1500);
}

function checkAnswer(i, element) {

  let correctIndex = quiz[index].answer;

  if (i === correctIndex) {
    element.classList.add("correct");

    showFlash("Correct Answer ✅", "success");

    score++;
    answeredCorrect = true;

  } else {
    element.classList.add("wrong");

    showFlash("Wrong Answer ❌ Try again!", "error");
  }
}

function nextQuestion() {

  if (!answeredCorrect) {
    showFlash("First select correct answer!", "error");
    return;
  }

  index++;

  if (index < quiz.length) {
    loadQuestion();
  } else {
    document.querySelector(".quiz-box").innerHTML =
      `<h2>Quiz Finished</h2>
       <p>Your Score: ${score} / ${quiz.length}</p>`;
  }
}

loadQuestion();

</script>

</body>
</html>