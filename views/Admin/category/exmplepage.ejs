<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Quiz App</title>


<style>
  body {
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(135deg, #c0c4da, #dfcbf2);
  margin: 0;
  padding: 0;
}

/* ================= QUIZ BOX ================= */
.quiz-box {
  width: 420px;
  margin: 60px auto;
  background: rgba(255, 255, 255, 0.95);
  padding: 25px;
  border-radius: 15px;
  box-shadow: 0 8px 25px rgba(0,0,0,0.2);
  animation: fadeIn 0.5s ease;
}

/* ================= TITLE ================= */
h2 {
  text-align: center;
  margin-bottom: 15px;
  color: #333;
}

/* ================= FLASH ================= */
#flashMsg {
  display: none;
  padding: 10px;
  margin-bottom: 12px;
  border-radius: 8px;
  font-weight: 500;
  text-align: center;
  animation: slideDown 0.3s ease;
}

.flash-success {
  background: #00b894;
  color: #fff;
}

.flash-error {
  background: #d63031;
  color: #fff;
}

/* ================= QUESTION ================= */
#question {
  font-size: 18px;
  font-weight: 600;
  margin-bottom: 10px;
  color: #2d3436;
}

/* ================= OPTIONS ================= */
.option {
  display: block;
  background: #f1f2f6;
  padding: 12px;
  margin: 8px 0;
  border-radius: 10px;
  cursor: pointer;
  transition: 0.3s;
  border: 2px solid transparent;
}

.option:hover {
  background: #dfe6e9;
  transform: translateX(5px);
}

/* ================= STATES ================= */
.correct {
  background: #00b894 !important;
  color: white;
  border-color: #00b894;
}

.wrong {
  background: #d63031 !important;
  color: white;
  border-color: #d63031;
}

/* ================= BUTTON ================= */
.btn {
  width: 100%;
  margin-top: 15px;
  padding: 12px;
  border: none;
  background: linear-gradient(135deg, #6c5ce7, #0984e3);
  color: white;
  font-size: 15px;
  border-radius: 10px;
  cursor: pointer;
  transition: 0.3s;
}

.btn:hover {
  transform: scale(1.05);
  box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}

/* ================= ANIMATION ================= */
@keyframes fadeIn {
  from {opacity: 0; transform: translateY(20px);}
  to {opacity: 1; transform: translateY(0);}
}

@keyframes slideDown {
  from {opacity: 0; transform: translateY(-10px);}
  to {opacity: 1; transform: translateY(0);}
}

/* ================= MOBILE ================= */
@media (max-width: 500px) {
  .quiz-box {
    width: 90%;
    margin: 30px auto;
  }
}
</style>

